@model IEnumerable<MedTrack.Models.Pharmacy>
@{
    ViewData["Title"] = "Pharmacies";
}

<div class="fade-in">
    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
        <div>
            <h2 class="fw-bold mb-1"><i class="bi bi-shop me-2"></i>Pharmacies</h2>
            <p class="text-muted mb-0">Registered pharmacies across Jordan</p>
        </div>
        @if (User.IsInRole("System Admin") || User.IsInRole("MOH Admin"))
        {
            <a asp-action="Create" class="btn btn-primary">
                <i class="bi bi-plus-lg me-1"></i>Add Pharmacy
            </a>
        }
    </div>

    <div class="card">
        <div class="table-responsive">
            <table class="table table-medtrack table-hover mb-0">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>License No</th>
                        <th>Governorate</th>
                        <th>Contact</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="fw-semibold">@item.Name</td>
                            <td><span class="badge bg-secondary">@item.LicenseNo</span></td>
                            <td>@item.Governorate</td>
                            <td>
                                <div class="small text-muted">@item.ContactEmail</div>
                                <div class="small text-muted">@item.Phone</div>
                            </td>
                            <td class="text-end">
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">
                                    <i class="bi bi-eye"></i>
                                </a>
                                @if (User.IsInRole("System Admin") || User.IsInRole("MOH Admin"))
                                {
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger">
                                        <i class="bi bi-trash"></i>
                                    </a>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        @if (!Model.Any())
        {
            <div class="text-center py-5 text-muted">
                <i class="bi bi-building-x fs-1"></i>
                <p class="mt-2 mb-0">No pharmacies registered yet.</p>
            </div>
        }
    </div>
</div>
