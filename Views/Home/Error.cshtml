@model MedTrack.Models.ErrorViewModel
@{
    ViewData["Title"] = "Error";
}

<div class="container py-5 text-center">
    <div class="mt-auth-icon mx-auto"><i class="bi bi-exclamation-octagon"></i></div>
    <h1 class="fw-bold mt-3">Something went wrong</h1>
    <p class="text-muted lead">An error occurred while processing your request.</p>
    @if (Model.ShowRequestId)
    {
        <p class="small text-muted">Request ID: <code>@Model.RequestId</code></p>
    }
    <div class="d-flex justify-content-center gap-2 mt-4 flex-wrap">
        <a href="/" class="btn-primary-mt"><i class="bi bi-house"></i> Go Home</a>
        <a href="javascript:history.back()" class="btn-ghost-mt">Go Back</a>
    </div>
</div>
