@{
    ViewData["Title"] = "Privacy Policy";
}

<div class="container">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card border-0">
                <div class="card-body p-4 p-md-5">
                    <div class="hero__eyebrow mb-3">Legal</div>
                    <h1 class="fw-bold mb-3">@ViewData["Title"]</h1>
                    <p class="text-muted">
                        MedTrack Jordan collects pharmacy inventory and operational data solely to support
                        medication tracking, expiry alerts, and national shortage analytics. No patient
                        personal health information is stored on this platform.
                    </p>
                    <p class="text-muted mb-0">
                        Aggregate-only data may be shared with the Ministry of Health for public health planning.
                        For questions, contact your pharmacy administrator or MOH liaison.
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>
