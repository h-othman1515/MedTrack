@model IEnumerable<MedTrackJordan.Models.SurplusPost>
@{ ViewData["Title"] = "My Surplus Posts"; }

<div class="d-flex justify-content-between align-items-center mb-4">
    <h3 class="fw-bold"><i class="bi bi-list-ul me-2"></i>My Surplus Posts</h3>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-lg me-1"></i>New Post
    </a>
</div>

<div class="card shadow-sm border-0">
    <div class="table-responsive">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th>Drug</th>
                    <th>Qty</th>
                    <th>Status</th>
                    <th>Requests</th>
                    <th>Posted</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="fw-semibold">@item.Drug.GenericName</td>
                        <td>@item.Quantity @item.Drug.Unit</td>
                        <td>
                            <span class="badge @(item.Status == MedTrackJordan.Models.SurplusStatus.Available ? "bg-success" : item.Status == MedTrackJordan.Models.SurplusStatus.Reserved ? "bg-warning text-dark" : "bg-secondary")">
                                @item.Status
                            </span>
                        </td>
                        <td>@item.TransferRequests.Count</td>
                        <td class="small text-muted">@item.PostedAt.ToString("yyyy-MM-dd")</td>
                        <td class="text-end">
                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger">
                                <i class="bi bi-trash"></i>
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    @if (!Model.Any())
    {
        <div class="text-center py-5 text-muted">
            <i class="bi bi-inbox fs-1"></i>
            <p class="mt-2">You haven not posted any surplus yet.</p>
        </div>
    }
</div>

<div class="mt-3">
    <a asp-action="Index" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left me-1"></i>Back to Board
    </a>
</div>