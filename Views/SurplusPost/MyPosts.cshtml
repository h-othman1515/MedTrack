@model IEnumerable<MedTrack.Models.SurplusPost>
@{
    ViewData["Title"] = "My Surplus Posts";
    var list = Model.ToList();
    var available = list.Count(p => p.Status == MedTrack.Models.SurplusStatus.Available);
    var reserved = list.Count(p => p.Status == MedTrack.Models.SurplusStatus.Reserved);
    var totalQty = list.Sum(p => p.Quantity);
}

<div class="fade-in">
    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
        <div>
            <h2 class="fw-bold mb-1"><i class="bi bi-tags me-2"></i>My Surplus Posts</h2>
            <p class="text-muted mb-0">Manage your surplus medication listings</p>
        </div>
        <a asp-action="Create" class="btn btn-primary">
            <i class="bi bi-plus-lg me-1"></i>New Post
        </a>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-xl-3 col-md-6">
            <div class="card text-center py-3">
                <div class="fs-2 fw-bold text-primary">@list.Count</div>
                <div class="small text-muted">Total Posts</div>
            </div>
        </div>
        <div class="col-xl-3 col-md-6">
            <div class="card text-center py-3">
                <div class="fs-2 fw-bold text-success">@available</div>
                <div class="small text-muted">Available</div>
            </div>
        </div>
        <div class="col-xl-3 col-md-6">
            <div class="card text-center py-3">
                <div class="fs-2 fw-bold text-warning">@reserved</div>
                <div class="small text-muted">Reserved</div>
            </div>
        </div>
        <div class="col-xl-3 col-md-6">
            <div class="card text-center py-3">
                <div class="fs-2 fw-bold text-primary">@totalQty</div>
                <div class="small text-muted">Total Units Listed</div>
            </div>
        </div>
    </div>

    <div class="card mb-4">
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-4">
                    <label class="form-label small text-muted">Search</label>
                    <div class="input-group">
                        <span class="input-group-text"><i class="bi bi-search"></i></span>
                        <input type="text" class="form-control" id="searchInput" placeholder="Drug name...">
                    </div>
                </div>
                <div class="col-md-3">
                    <label class="form-label small text-muted">Status</label>
                    <select class="form-select" id="filterStatus">
                        <option value="">All Statuses</option>
                        <option value="Available">Available</option>
                        <option value="Reserved">Reserved</option>
                        <option value="Completed">Completed</option>
                        <option value="Expired">Expired</option>
                    </select>
                </div>
                <div class="col-md-3 d-flex align-items-end">
                    <button class="btn btn-outline-secondary w-100" onclick="resetFilters()">
                        <i class="bi bi-arrow-counterclockwise me-1"></i>Reset Filters
                    </button>
                </div>
            </div>
        </div>
    </div>

    <div class="card">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-medtrack mb-0" id="surplusPostsTable">
                    <thead>
                        <tr>
                            <th>Drug</th>
                            <th>Qty</th>
                            <th>Status</th>
                            <th>Requests</th>
                            <th>Posted</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in list)
                        {
                            var statusName = item.Status.ToString();
                            var statusBadge = item.Status == MedTrack.Models.SurplusStatus.Available ? "success"
                                : item.Status == MedTrack.Models.SurplusStatus.Reserved ? "warning text-dark" : "secondary";
                            <tr data-status="@statusName">
                                <td class="fw-semibold">@item.Drug.GenericName</td>
                                <td>@item.Quantity @item.Drug.DefaultUnit</td>
                                <td><span class="badge bg-@statusBadge">@statusName</span></td>
                                <td>@item.TransferRequests.Count</td>
                                <td class="small text-muted">@item.PostedAt.ToString("yyyy-MM-dd")</td>
                                <td class="text-end">
                                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger" title="Delete">
                                        <i class="bi bi-trash"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                        @if (!list.Any())
                        {
                            <tr>
                                <td colspan="6" class="text-center py-5 text-muted">
                                    <i class="bi bi-inbox fs-1 d-block mb-2"></i>
                                    You have not posted any surplus yet.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
        <div class="card-footer bg-transparent">
            <div class="d-flex justify-content-between align-items-center">
                <span class="text-muted small" id="rowCount">Showing @list.Count items</span>
                <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
                    <i class="bi bi-arrow-left me-1"></i>Back to Board
                </a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function filterRows() {
            var search = $('#searchInput').val().toLowerCase();
            var status = $('#filterStatus').val();
            var visible = 0;

            $('#surplusPostsTable tbody tr').each(function () {
                var $row = $(this);
                if ($row.find('td[colspan]').length) return;

                var text = $row.text().toLowerCase();
                var rowStatus = $row.data('status');

                var show = true;
                if (search && text.indexOf(search) === -1) show = false;
                if (status && rowStatus !== status) show = false;

                $row.toggle(show);
                if (show) visible++;
            });

            $('#rowCount').text('Showing ' + visible + ' items');
        }

        function resetFilters() {
            $('#searchInput').val('');
            $('#filterStatus').val('');
            $('#surplusPostsTable tbody tr').show();
            $('#rowCount').text('Showing @list.Count items');
        }

        $('#searchInput').on('keyup', filterRows);
        $('#filterStatus').on('change', filterRows);
    </script>
}
