@model IEnumerable<MedTrack.Models.SurplusPost>
@{ ViewData["Title"] = "My Surplus Posts"; }

<div class="fade-in">
    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
        <div>
            <h2 class="fw-bold mb-1"><i class="bi bi-tags me-2"></i>My Surplus Posts</h2>
            <p class="text-muted mb-0">Manage your surplus medication listings</p>
        </div>
        <a asp-action="Create" class="btn btn-primary">
            <i class="bi bi-plus-lg me-1"></i>New Post
        </a>
    </div>

    <div class="card">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-medtrack mb-0">
                    <thead>
                        <tr>
                            <th>Drug</th>
                            <th>Qty</th>
                            <th>Status</th>
                            <th>Requests</th>
                            <th>Posted</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="fw-semibold">@item.Drug.GenericName</td>
                                <td>@item.Quantity @item.Drug.DefaultUnit</td>
                                <td>
                                    <span class="badge @(item.Status == MedTrack.Models.SurplusStatus.Available ? "bg-success" : item.Status == MedTrack.Models.SurplusStatus.Reserved ? "bg-warning text-dark" : "bg-secondary")">
                                        @item.Status
                                    </span>
                                </td>
                                <td>@item.TransferRequests.Count</td>
                                <td class="small text-muted">@item.PostedAt.ToString("yyyy-MM-dd")</td>
                                <td class="text-end">
                                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger">
                                        <i class="bi bi-trash"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            @if (!Model.Any())
            {
                <div class="text-center py-5 text-muted">
                    <i class="bi bi-inbox fs-1"></i>
                    <p class="mt-2">You haven not posted any surplus yet.</p>
                </div>
            }
        </div>
    </div>

    <div class="mt-3">
        <a asp-action="Index" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left me-1"></i>Back to Board
        </a>
    </div>
</div>
