@model MedTrack.Models.ViewModels.CsvImportViewModel
@{
    ViewData["Title"] = "Import Inventory";
    Layout = "_Layout";
}

<div class="fade-in">
    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
        <div>
            <h2 class="fw-bold mb-1"><i class="bi bi-box-seam me-2"></i>Import Inventory</h2>
            <p class="text-muted mb-0">Bulk import medication batches from a CSV file</p>
        </div>
        <a href="/Inventory" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left me-1"></i>Back to Inventory
        </a>
    </div>

    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card">
                <div class="card-header bg-white">
                    <h5 class="fw-bold mb-0"><i class="bi bi-upload me-2"></i>Bulk Import via CSV</h5>
                </div>
                <div class="card-body p-4">
                    <div class="alert alert-info d-flex align-items-start">
                        <i class="bi bi-info-circle fs-4 me-3"></i>
                        <div>
                            <h6 class="fw-bold">CSV Format Requirements</h6>
                            <p class="mb-2">Your CSV file must include these columns in order:</p>
                            <code class="d-block bg-light p-2 rounded mb-2">
                                DrugName, GenericName, Category, BatchNo, Quantity, Unit, MinStockLevel, UnitPrice, ExpiryDate
                            </code>
                            <p class="small mb-0">Date format: <strong>yyyy-MM-dd</strong> (e.g., 2026-12-31)</p>
                        </div>
                    </div>

                    <form asp-action="Import" method="post" enctype="multipart/form-data">
                        <div class="mb-3">
                            <label class="form-label fw-bold">Select CSV File</label>
                            <div class="input-group mb-2">
                                <input type="file" class="form-control" id="csvFile" name="csvFile" accept=".csv" required />
                                <button class="btn btn-outline-secondary" type="button" onclick="document.getElementById('csvFile').value=''">
                                    <i class="bi bi-x-lg"></i>
                                </button>
                            </div>
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" id="hasHeaders" name="hasHeaders" checked />
                                <label class="form-check-label" for="hasHeaders">
                                    First row contains headers
                                </label>
                            </div>
                        </div>

                        <div id="importPreview" class="d-none">
                            <h6 class="fw-bold mt-4">Preview</h6>
                            <div class="table-responsive">
                                <table class="table table-sm table-bordered">
                                    <thead class="table-light">
                                        <tr>
                                            <th>DrugName</th>
                                            <th>GenericName</th>
                                            <th>Category</th>
                                            <th>BatchNo</th>
                                            <th>Qty</th>
                                            <th>Unit</th>
                                            <th>Min</th>
                                            <th>Price</th>
                                            <th>Expiry</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <tr>
                                            <td>Amoxicillin 500mg</td>
                                            <td>Amoxicillin</td>
                                            <td>Antibiotics</td>
                                            <td>AMX20250601</td>
                                            <td>100</td>
                                            <td>Capsules</td>
                                            <td>20</td>
                                            <td>8.50</td>
                                            <td>2026-11-15</td>
                                        </tr>
                                        <tr>
                                            <td>Metformin 850mg</td>
                                            <td>Metformin HCl</td>
                                            <td>Diabetes</td>
                                            <td>MET20250615</td>
                                            <td>200</td>
                                            <td>Tablets</td>
                                            <td>50</td>
                                            <td>12.00</td>
                                            <td>2027-03-20</td>
                                        </tr>
                                    </tbody>
                                </table>
                            </div>
                            <div class="alert alert-warning">
                                <i class="bi bi-exclamation-triangle me-2"></i>
                                This is a sample preview. Upload your file to see actual data.
                            </div>
                        </div>

                        <div class="d-flex justify-content-between mt-4">
                            <a href="/Inventory" class="btn btn-outline-secondary">Cancel</a>
                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-upload me-1"></i>Import Items
                            </button>
                        </div>
                    </form>
                </div>
            </div>

            <!-- Download Template -->
            <div class="card mt-3 border-success">
                <div class="card-body d-flex align-items-center">
                    <div class="bg-success bg-opacity-10 text-success rounded-3 p-3 me-3">
                        <i class="bi bi-file-earmark-spreadsheet fs-3"></i>
                    </div>
                    <div class="flex-grow-1">
                        <h6 class="fw-bold mb-1">Download Template</h6>
                        <p class="small text-muted mb-0">Get a pre-formatted CSV template with the correct column structure.</p>
                    </div>
                    <a href="/templates/inventory_template.csv" class="btn btn-success" download>
                        <i class="bi bi-download me-1"></i>Download
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
