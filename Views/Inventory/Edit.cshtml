@model MedTrack.Models.ViewModels.InventoryCreateViewModel
@{
    ViewData["Title"] = "Edit Inventory Item";
    Layout = "_Layout";
    var batchId = ViewContext.RouteData.Values["id"];
}

<div class="fade-in">
    <div class="mb-4">
        <a href="/Inventory" class="text-decoration-none text-muted">
            <i class="bi bi-arrow-left me-1"></i>Back to Inventory
        </a>
    </div>

    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card">
                <div class="card-header bg-white">
                    <h4 class="fw-bold mb-0"><i class="bi bi-pencil-square me-2"></i>Edit Medication Batch</h4>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Edit" asp-route-id="@batchId" method="post">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                        <div class="row g-3">
                            <div class="col-12">
                                <h6 class="fw-bold text-primary mb-3">Drug Information</h6>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="DrugName" class="form-label"></label>
                                <input asp-for="DrugName" class="form-control" />
                                <span asp-validation-for="DrugName" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="GenericName" class="form-label"></label>
                                <input asp-for="GenericName" class="form-control" />
                                <span asp-validation-for="GenericName" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="Category" class="form-label"></label>
                                <select asp-for="Category" class="form-select">
                                    <option value="">Select Category</option>
                                    <option>Antibiotics</option>
                                    <option>Antiviral</option>
                                    <option>Cardiovascular</option>
                                    <option>Diabetes</option>
                                    <option>Gastrointestinal</option>
                                    <option>Pain Relief</option>
                                    <option>Respiratory</option>
                                    <option>Vitamins & Supplements</option>
                                    <option>Other</option>
                                </select>
                                <span asp-validation-for="Category" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="BatchNo" class="form-label"></label>
                                <input asp-for="BatchNo" class="form-control" />
                                <span asp-validation-for="BatchNo" class="text-danger small"></span>
                            </div>

                            <div class="col-12 mt-2">
                                <h6 class="fw-bold text-primary mb-3">Stock Information</h6>
                            </div>

                            <div class="col-md-4">
                                <label asp-for="Quantity" class="form-label"></label>
                                <input asp-for="Quantity" class="form-control" type="number" min="0" />
                                <span asp-validation-for="Quantity" class="text-danger small"></span>
                            </div>

                            <div class="col-md-4">
                                <label asp-for="Unit" class="form-label"></label>
                                <select asp-for="Unit" class="form-select">
                                    <option value="">Select Unit</option>
                                    <option>Tablets</option>
                                    <option>Capsules</option>
                                    <option>Bottles</option>
                                    <option>Boxes</option>
                                    <option>Vials</option>
                                    <option>Ampoules</option>
                                    <option>Tubes</option>
                                    <option>Packs</option>
                                </select>
                                <span asp-validation-for="Unit" class="text-danger small"></span>
                            </div>

                            <div class="col-md-4">
                                <label asp-for="MinStockLevel" class="form-label"></label>
                                <input asp-for="MinStockLevel" class="form-control" type="number" min="0" />
                                <span asp-validation-for="MinStockLevel" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="UnitPrice" class="form-label"></label>
                                <div class="input-group">
                                    <span class="input-group-text">JOD</span>
                                    <input asp-for="UnitPrice" class="form-control" type="number" step="0.01" min="0" />
                                </div>
                                <span asp-validation-for="UnitPrice" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="ExpiryDate" class="form-label"></label>
                                <input asp-for="ExpiryDate" class="form-control" type="date" />
                                <span asp-validation-for="ExpiryDate" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="d-flex justify-content-between mt-4 pt-3 border-top">
                            <a href="/Inventory" class="btn btn-outline-secondary">Cancel</a>
                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-check-lg me-1"></i>Save Changes
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
