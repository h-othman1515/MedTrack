@model MedTrackJordan.Models.TransferRequest
@{
    ViewData["Title"] = "Request Transfer";
    var post = ViewBag.SurplusPost as MedTrackJordan.Models.SurplusPost;
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card shadow-sm border-0">
            <div class="card-body p-4">
                <h4 class="fw-bold mb-4"><i class="bi bi-send me-2"></i>Request Transfer</h4>

                <div class="alert alert-light border mb-4">
                    <div class="fw-bold">@post.Drug.GenericName</div>
                    <div class="small text-muted">
                        @post.Quantity @post.Drug.Unit from @post.Pharmacy.Name
                    </div>
                    @if (post.ExpiryDate.HasValue)
                    {
                        <div class="small text-muted">Expires: @post.ExpiryDate.Value.ToString("yyyy-MM-dd")</div>
                    }
                </div>

                <form asp-action="Create">
                    <input type="hidden" asp-for="SurplusPostId" value="@post.Id" />
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small"></div>

                    <div class="mb-4">
                        <label asp-for="RequestingPharmacyId" class="form-label fw-semibold">Requesting Pharmacy</label>
                        <select asp-for="RequestingPharmacyId" class="form-select"
                                asp-items="@(new SelectList(ViewBag.Pharmacies, "Id", "Name"))">
                            <option value="">-- Select Pharmacy --</option>
                        </select>
                        <span asp-validation-for="RequestingPharmacyId" class="text-danger small"></span>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary fw-semibold">
                            <i class="bi bi-send me-1"></i>Send Request
                        </button>
                        <a asp-controller="SurplusPost" asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}