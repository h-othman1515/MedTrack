@{
    ViewData["Title"] = "Notification History";
    Layout = "_Layout";
}

<div class="fade-in">
    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
        <div>
            <h2 class="fw-bold mb-1"><i class="bi bi-clock-history me-2"></i>Notification History</h2>
            <p class="text-muted mb-0">Log of broadcasts and system notifications sent</p>
        </div>
        <a href="/Admin/Notifications" class="btn btn-primary"><i class="bi bi-broadcast me-1"></i>New Broadcast</a>
    </div>

    <div class="card">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Sent</th>
                        <th>Type</th>
                        <th>Channel</th>
                        <th>Audience</th>
                        <th>Message</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var n in new[] {
                        new { When = "2026-06-08 09:12", Type = "Broadcast", Channel = "SMS", Audience = "All Pharmacies", Msg = "Insulin shortage reported in Zarqa - please report surplus." },
                        new { When = "2026-06-07 14:40", Type = "System", Channel = "In-App", Audience = "MOH Admins", Msg = "Monthly waste report is ready for review." },
                        new { When = "2026-06-05 08:05", Type = "Broadcast", Channel = "Email", Audience = "Amman region", Msg = "Reminder: update expiry dates for Q2 stock." }
                    })
                    {
                        <tr>
                            <td class="small text-muted">@n.When</td>
                            <td><span class="badge bg-secondary">@n.Type</span></td>
                            <td>@n.Channel</td>
                            <td>@n.Audience</td>
                            <td>@n.Msg</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
