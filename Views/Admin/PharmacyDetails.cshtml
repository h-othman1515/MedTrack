@{
    ViewData["Title"] = "Pharmacy Details";
    ViewData["PageIcon"] = "bi-shop";
    ViewData["Subtitle"] = "Pharmacy profile and management";
    ViewData["BackUrl"] = "/Admin/Pharmacies";
    var id = ViewContext.RouteData.Values["id"]?.ToString();
}

<div class="fade-in">
    <partial name="_PageHeader" />

    <div class="row g-4">
        <div class="col-lg-8">
            <div class="card mb-4">
                <div class="card-header bg-white py-3">
                    <h5 class="fw-bold mb-0"><i class="bi bi-shop me-2"></i>Profile</h5>
                </div>
                <div class="card-body">
                    <dl class="row mb-0">
                        <dt class="col-sm-3">Reference</dt>
                        <dd class="col-sm-9"><code>#@id</code></dd>
                        <dt class="col-sm-3">Status</dt>
                        <dd class="col-sm-9"><span class="badge bg-success">Active</span></dd>
                        <dt class="col-sm-3">Governorate</dt>
                        <dd class="col-sm-9">Amman</dd>
                        <dt class="col-sm-3">Tier</dt>
                        <dd class="col-sm-9"><span class="badge bg-info text-dark">Professional</span></dd>
                    </dl>
                </div>
            </div>
        </div>
        <div class="col-lg-4">
            <div class="card">
                <div class="card-body text-center">
                    <i class="bi bi-building text-primary" style="font-size:3rem"></i>
                    <p class="text-muted mt-2 mb-3">Manage this pharmacy's catalogue entry.</p>
                    <a href="/Pharmacy/Edit/@id" class="btn btn-outline-primary w-100 mb-2"><i class="bi bi-pencil me-1"></i>Edit</a>
                    <a href="/Pharmacy/Details/@id" class="btn btn-outline-secondary w-100"><i class="bi bi-eye me-1"></i>Full Inventory View</a>
                </div>
            </div>
        </div>
    </div>
</div>
