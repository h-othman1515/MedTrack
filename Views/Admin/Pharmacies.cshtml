@model MedTrack.Models.ViewModels.PharmacyManagementViewModel
@{
    ViewData["Title"] = "Pharmacy Management";
    Layout = "_Layout";
}

<div class="fade-in">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-1"><i class="bi bi-shop me-2"></i>Pharmacy Management</h2>
            <p class="text-muted mb-0">Approve, monitor, and manage registered pharmacies</p>
        </div>
        <div class="d-flex gap-2">
            <button class="btn btn-outline-secondary" onclick="exportTableToCSV('pharmacyTable', 'pharmacies.csv')">
                <i class="bi bi-download me-1"></i>Export
            </button>
            <a href="/Admin/RegisterPharmacy" class="btn btn-primary">
                <i class="bi bi-plus-lg me-1"></i>Register Pharmacy
            </a>
        </div>
    </div>

    <!-- Summary Cards -->
    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <div class="card border-success">
                <div class="card-body text-center">
                    <h4 class="fw-bold text-success mb-1">@Model.ActiveCount</h4>
                    <small class="text-muted">Active</small>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-warning">
                <div class="card-body text-center">
                    <h4 class="fw-bold text-warning mb-1">@Model.PendingCount</h4>
                    <small class="text-muted">Pending Approval</small>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-danger">
                <div class="card-body text-center">
                    <h4 class="fw-bold text-danger mb-1">@Model.SuspendedCount</h4>
                    <small class="text-muted">Suspended</small>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-secondary">
                <div class="card-body text-center">
                    <h4 class="fw-bold text-secondary mb-1">@Model.TotalCount</h4>
                    <small class="text-muted">Total</small>
                </div>
            </div>
        </div>
    </div>

    <!-- Filters -->
    <div class="card mb-4">
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-3">
                    <div class="input-group">
                        <span class="input-group-text"><i class="bi bi-search"></i></span>
                        <input type="text" class="form-control" id="searchPharmacies" placeholder="Pharmacy name or license...">
                    </div>
                </div>
                <div class="col-md-2">
                    <select class="form-select" id="filterPharmacyStatus">
                        <option value="">All Status</option>
                        <option value="Active">Active</option>
                        <option value="Pending">Pending</option>
                        <option value="Suspended">Suspended</option>
                        <option value="Rejected">Rejected</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <select class="form-select" id="filterPharmacyGov">
                        <option value="">All Governorates</option>
                        <option>Amman</option>
                        <option>Irbid</option>
                        <option>Zarqa</option>
                        <option>Balqa</option>
                        <option>Madaba</option>
                        <option>Mafraq</option>
                        <option>Karak</option>
                        <option>Aqaba</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <select class="form-select" id="filterTier">
                        <option value="">All Tiers</option>
                        <option>Basic</option>
                        <option>Professional</option>
                        <option>Enterprise</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <button class="btn btn-outline-secondary w-100" onclick="resetPharmacyFilters()">
                        <i class="bi bi-arrow-counterclockwise me-1"></i>Reset
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Pharmacies Table -->
    <div class="card">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-medtrack mb-0 datatable" id="pharmacyTable">
                    <thead>
                        <tr>
                            <th><input type="checkbox" class="form-check-input" id="selectAllPharmacies"></th>
                            <th>Pharmacy</th>
                            <th>License</th>
                            <th>Governorate</th>
                            <th>Manager</th>
                            <th>Tier</th>
                            <th>Inventory</th>
                            <th>Status</th>
                            <th>Joined</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var pharmacy in Model.Pharmacies)
                        {
                            <tr>
                                <td><input type="checkbox" class="form-check-input row-checkbox"></td>
                                <td>
                                    <div class="fw-bold">@pharmacy.Name</div>
                                    <small class="text-muted">@pharmacy.Email</small>
                                </td>
                                <td><code>@pharmacy.LicenseNo</code></td>
                                <td>@pharmacy.Governorate</td>
                                <td>@pharmacy.ManagerName</td>
                                <td>
                                    <span class="badge bg-@(pharmacy.Tier == "Enterprise" ? "dark" : pharmacy.Tier == "Professional" ? "primary" : "secondary")">
                                        @pharmacy.Tier
                                    </span>
                                </td>
                                <td>
                                    <span class="fw-bold">@pharmacy.InventoryCount</span>
                                    <small class="text-muted">items</small>
                                </td>
                                <td>
                                    @switch (pharmacy.Status)
                                    {
                                        case "Active":
                                            <span class="status-badge status-healthy">Active</span>
                                            break;
                                        case "Pending":
                                            <span class="status-badge status-warning">Pending</span>
                                            break;
                                        case "Suspended":
                                            <span class="status-badge status-danger">Suspended</span>
                                            break;
                                        case "Rejected":
                                            <span class="badge bg-secondary">Rejected</span>
                                            break;
                                    }
                                </td>
                                <td>@pharmacy.CreatedAt.ToString("MMM dd, yyyy")</td>
                                <td>
                                    <div class="btn-group btn-group-sm">
                                        <a href="/Admin/PharmacyDetails/@pharmacy.Id" class="btn btn-outline-secondary" data-bs-toggle="tooltip" title="Details">
                                            <i class="bi bi-eye"></i>
                                        </a>
                                        @if (pharmacy.Status == "Pending")
                                        {
                                            <button type="button" class="btn btn-success"
                                                    data-mt-swal-message="Approve this pharmacy registration?"
                                                    data-mt-swal-title="Approve pharmacy"
                                                    data-mt-swal-icon="question"
                                                    data-mt-swal-confirm-text="Approve"
                                                    data-mt-swal-success="Pharmacy approved successfully"
                                                    data-bs-toggle="tooltip" title="Approve">
                                                <i class="bi bi-check-lg"></i>
                                            </button>
                                            <button type="button" class="btn btn-danger"
                                                    data-mt-swal-message="Reject this pharmacy registration? This action cannot be undone."
                                                    data-mt-swal-title="Reject pharmacy"
                                                    data-mt-swal-icon="warning"
                                                    data-mt-swal-danger="true"
                                                    data-mt-swal-confirm-text="Reject"
                                                    data-mt-swal-success="Pharmacy rejected"
                                                    data-mt-swal-success-type="warning"
                                                    data-bs-toggle="tooltip" title="Reject">
                                                <i class="bi bi-x-lg"></i>
                                            </button>
                                        }
                                        else if (pharmacy.Status == "Active")
                                        {
                                            <button type="button" class="btn btn-outline-warning"
                                                    data-mt-swal-message="Suspend this pharmacy? They will be unable to access the platform."
                                                    data-mt-swal-title="Suspend pharmacy"
                                                    data-mt-swal-icon="warning"
                                                    data-mt-swal-confirm-text="Suspend"
                                                    data-mt-swal-success="Pharmacy suspended"
                                                    data-mt-swal-success-type="warning"
                                                    data-bs-toggle="tooltip" title="Suspend">
                                                <i class="bi bi-pause-circle"></i>
                                            </button>
                                        }
                                        else if (pharmacy.Status == "Suspended")
                                        {
                                            <button type="button" class="btn btn-outline-success" onclick="reactivatePharmacy()" data-bs-toggle="tooltip" title="Reactivate">
                                                <i class="bi bi-play-circle"></i>
                                            </button>
                                        }
                                        <button type="button" class="btn btn-outline-danger"
                                                data-mt-swal-message="Delete this pharmacy permanently? All data will be removed."
                                                data-mt-swal-title="Delete pharmacy"
                                                data-mt-swal-icon="warning"
                                                data-mt-swal-danger="true"
                                                data-mt-swal-confirm-text="Delete"
                                                data-mt-swal-success="Pharmacy deleted"
                                                data-bs-toggle="tooltip" title="Delete">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                        @if (!Model.Pharmacies.Any())
                        {
                            @foreach (var demo in new[] {
                                new { Id = 1, Name = "Al-Shifa Pharmacy", Email = "info@alshifa.jo", License = "MOH-2025-00120", Gov = "Amman", Manager = "Ahmad Khalil", Tier = "Professional", Inventory = 342, Status = "Active", Created = DateTime.Now.AddMonths(-3) },
                                new { Id = 2, Name = "Irbid Care Center", Email = "contact@irbidcare.jo", License = "MOH-2025-00135", Gov = "Irbid", Manager = "Sara Nasser", Tier = "Basic", Inventory = 156, Status = "Active", Created = DateTime.Now.AddMonths(-2) },
                                new { Id = 3, Name = "Zarqa Health Plus", Email = "admin@zarqahealth.jo", License = "MOH-2026-00144", Gov = "Zarqa", Manager = "Omar Haddad", Tier = "Basic", Inventory = 0, Status = "Pending", Created = DateTime.Now.AddDays(-2) },
                                new { Id = 4, Name = "Rainbow Pharmacy", Email = "rainbow@pharma.jo", License = "MOH-2025-00098", Gov = "Amman", Manager = "Lina Farah", Tier = "Enterprise", Inventory = 520, Status = "Active", Created = DateTime.Now.AddMonths(-6) },
                                new { Id = 5, Name = "Salt City Pharma", Email = "salt@pharma.jo", License = "MOH-2025-00115", Gov = "Balqa", Manager = "Khaled Omar", Tier = "Professional", Inventory = 89, Status = "Suspended", Created = DateTime.Now.AddMonths(-1) },
                                new { Id = 6, Name = "Madaba Care", Email = "care@madaba.jo", License = "MOH-2026-00140", Gov = "Madaba", Manager = "Rana Suleiman", Tier = "Basic", Inventory = 0, Status = "Rejected", Created = DateTime.Now.AddDays(-5) }
                            })
                            {
                                <tr>
                                    <td><input type="checkbox" class="form-check-input row-checkbox"></td>
                                    <td>
                                        <div class="fw-bold">@demo.Name</div>
                                        <small class="text-muted">@demo.Email</small>
                                    </td>
                                    <td><code>@demo.License</code></td>
                                    <td>@demo.Gov</td>
                                    <td>@demo.Manager</td>
                                    <td>
                                        <span class="badge bg-@(demo.Tier == "Enterprise" ? "dark" : demo.Tier == "Professional" ? "primary" : "secondary")">
                                            @demo.Tier
                                        </span>
                                    </td>
                                    <td>
                                        <span class="fw-bold">@demo.Inventory</span>
                                        <small class="text-muted">items</small>
                                    </td>
                                    <td>
                                        @if (demo.Status == "Active")
                                        {
                                            <span class="status-badge status-healthy">Active</span>
                                        }
                                        else if (demo.Status == "Pending")
                                        {
                                            <span class="status-badge status-warning">Pending</span>
                                        }
                                        else if (demo.Status == "Suspended")
                                        {
                                            <span class="status-badge status-danger">Suspended</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">Rejected</span>
                                        }
                                    </td>
                                    <td>@demo.Created.ToString("MMM dd, yyyy")</td>
                                    <td>
                                        <div class="btn-group btn-group-sm">
                                            <a href="/Admin/PharmacyDetails/@demo.Id" class="btn btn-outline-secondary" data-bs-toggle="tooltip" title="Details">
                                                <i class="bi bi-eye"></i>
                                            </a>
                                            @if (demo.Status == "Pending")
                                            {
                                                <button type="button" class="btn btn-success"
                                                        data-mt-swal-message="Approve this pharmacy registration?"
                                                        data-mt-swal-title="Approve pharmacy"
                                                        data-mt-swal-icon="question"
                                                        data-mt-swal-confirm-text="Approve"
                                                        data-mt-swal-success="Pharmacy approved successfully"
                                                        data-bs-toggle="tooltip" title="Approve">
                                                    <i class="bi bi-check-lg"></i>
                                                </button>
                                                <button type="button" class="btn btn-danger"
                                                        data-mt-swal-message="Reject this pharmacy registration? This action cannot be undone."
                                                        data-mt-swal-title="Reject pharmacy"
                                                        data-mt-swal-icon="warning"
                                                        data-mt-swal-danger="true"
                                                        data-mt-swal-confirm-text="Reject"
                                                        data-mt-swal-success="Pharmacy rejected"
                                                        data-mt-swal-success-type="warning"
                                                        data-bs-toggle="tooltip" title="Reject">
                                                    <i class="bi bi-x-lg"></i>
                                                </button>
                                            }
                                            else if (demo.Status == "Active")
                                            {
                                                <button type="button" class="btn btn-outline-warning"
                                                        data-mt-swal-message="Suspend this pharmacy? They will be unable to access the platform."
                                                        data-mt-swal-title="Suspend pharmacy"
                                                        data-mt-swal-icon="warning"
                                                        data-mt-swal-confirm-text="Suspend"
                                                        data-mt-swal-success="Pharmacy suspended"
                                                        data-mt-swal-success-type="warning"
                                                        data-bs-toggle="tooltip" title="Suspend">
                                                    <i class="bi bi-pause-circle"></i>
                                                </button>
                                            }
                                            else if (demo.Status == "Suspended")
                                            {
                                                <button type="button" class="btn btn-outline-success" onclick="reactivatePharmacy()" data-bs-toggle="tooltip" title="Reactivate">
                                                    <i class="bi bi-play-circle"></i>
                                                </button>
                                            }
                                            <button type="button" class="btn btn-outline-danger"
                                                    data-mt-swal-message="Delete this pharmacy permanently? All data will be removed."
                                                    data-mt-swal-title="Delete pharmacy"
                                                    data-mt-swal-icon="warning"
                                                    data-mt-swal-danger="true"
                                                    data-mt-swal-confirm-text="Delete"
                                                    data-mt-swal-success="Pharmacy deleted"
                                                    data-bs-toggle="tooltip" title="Delete">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function reactivatePharmacy() {
            showToast('Pharmacy reactivated', 'success');
        }
        function resetPharmacyFilters() {
            $('#searchPharmacies').val('');
            $('#filterPharmacyStatus').val('');
            $('#filterPharmacyGov').val('');
            $('#filterTier').val('');
            $('#pharmacyTable tbody tr').show();
        }
        $('#searchPharmacies').on('keyup', function() {
            var value = $(this).val().toLowerCase();
            $('#pharmacyTable tbody tr').filter(function() {
                $(this).toggle($(this).text().toLowerCase().indexOf(value) > -1);
            });
        });
    </script>
}
