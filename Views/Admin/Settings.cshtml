@model MedTrack.Models.ViewModels.SystemSettingsViewModel
@{
    ViewData["Title"] = "System Settings";
    Layout = "_Layout";
}

<div class="fade-in">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-1"><i class="bi bi-gear me-2"></i>System Settings</h2>
            <p class="text-muted mb-0">Configure platform behavior, thresholds, and integrations</p>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-lg-8">
            <form asp-action="SaveSettings" method="post">
                <!-- Alert Settings -->
                <div class="card mb-4">
                    <div class="card-header bg-white">
                        <h5 class="fw-bold mb-0"><i class="bi bi-bell me-2 text-warning"></i>Alert Configuration</h5>
                    </div>
                    <div class="card-body">
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label">Expiry Warning Days</label>
                                <div class="input-group">
                                    <span class="input-group-text">60</span>
                                    <input type="number" class="form-control" name="ExpiryAlert60" value="60" />
                                    <span class="input-group-text">days</span>
                                </div>
                                <div class="form-text">First warning threshold</div>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Critical Expiry Days</label>
                                <div class="input-group">
                                    <span class="input-group-text text-danger">30</span>
                                    <input type="number" class="form-control" name="ExpiryAlert30" value="30" />
                                    <span class="input-group-text">days</span>
                                </div>
                                <div class="form-text">Critical warning threshold</div>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Final Expiry Days</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-danger text-white">7</span>
                                    <input type="number" class="form-control" name="ExpiryAlert7" value="7" />
                                    <span class="input-group-text">days</span>
                                </div>
                                <div class="form-text">Final urgent warning</div>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Shortage Detection Threshold</label>
                                <div class="input-group">
                                    <input type="number" class="form-control" name="ShortageThreshold" value="3" />
                                    <span class="input-group-text">pharmacies</span>
                                </div>
                                <div class="form-text">Min pharmacies in governorate to trigger shortage</div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Notification Settings -->
                <div class="card mb-4">
                    <div class="card-header bg-white">
                        <h5 class="fw-bold mb-0"><i class="bi bi-envelope me-2 text-primary"></i>Notification Channels</h5>
                    </div>
                    <div class="card-body">
                        <div class="row g-3">
                            <div class="col-md-6">
                                <div class="form-check form-switch mb-2">
                                    <input class="form-check-input" type="checkbox" id="smsEnabled" name="SmsEnabled" checked>
                                    <label class="form-check-label" for="smsEnabled">SMS Alerts (Orange Network)</label>
                                </div>
                                <div class="form-check form-switch mb-2">
                                    <input class="form-check-input" type="checkbox" id="emailEnabled" name="EmailEnabled" checked>
                                    <label class="form-check-label" for="emailEnabled">Email Alerts (SendGrid)</label>
                                </div>
                                <div class="form-check form-switch">
                                    <input class="form-check-input" type="checkbox" id="inAppEnabled" name="InAppEnabled" checked>
                                    <label class="form-check-label" for="inAppEnabled">In-App Notifications</label>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">SMS Sender ID</label>
                                <input type="text" class="form-control" name="SmsSenderId" value="MedTrack" />
                                <div class="form-text">Displayed as sender for SMS alerts</div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Platform Settings -->
                <div class="card mb-4">
                    <div class="card-header bg-white">
                        <h5 class="fw-bold mb-0"><i class="bi bi-sliders me-2 text-info"></i>Platform Behavior</h5>
                    </div>
                    <div class="card-body">
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label">Auto-Restock Threshold</label>
                                <div class="input-group">
                                    <input type="number" class="form-control" name="AutoRestockThreshold" value="1.0" step="0.1" />
                                    <span class="input-group-text">x min stock</span>
                                </div>
                                <div class="form-text">Trigger restock when stock falls below this multiplier of minimum</div>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Max Surplus Listing Days</label>
                                <div class="input-group">
                                    <input type="number" class="form-control" name="MaxSurplusDays" value="30" />
                                    <span class="input-group-text">days</span>
                                </div>
                                <div class="form-text">Auto-expire surplus listings after this period</div>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Session Timeout</label>
                                <div class="input-group">
                                    <input type="number" class="form-control" name="SessionTimeout" value="30" />
                                    <span class="input-group-text">minutes</span>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Password Expiry</label>
                                <div class="input-group">
                                    <input type="number" class="form-control" name="PasswordExpiryDays" value="90" />
                                    <span class="input-group-text">days</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Maintenance Mode -->
                <div class="card mb-4 border-warning">
                    <div class="card-header bg-warning bg-opacity-10">
                        <h5 class="fw-bold mb-0 text-warning"><i class="bi bi-exclamation-triangle me-2"></i>Maintenance Mode</h5>
                    </div>
                    <div class="card-body">
                        <div class="form-check form-switch mb-3">
                            <input class="form-check-input" type="checkbox" id="maintenanceMode" name="MaintenanceMode">
                            <label class="form-check-label fw-bold text-danger" for="maintenanceMode">Enable Maintenance Mode</label>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Maintenance Message</label>
                            <textarea class="form-control" name="MaintenanceMessage" rows="2">MedTrack is currently under maintenance. Please check back later.</textarea>
                        </div>
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label">Start Time</label>
                                <input type="datetime-local" class="form-control" name="MaintenanceStart" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">End Time</label>
                                <input type="datetime-local" class="form-control" name="MaintenanceEnd" />
                            </div>
                        </div>
                    </div>
                </div>

                <div class="d-flex justify-content-between">
                    <button type="button" class="btn btn-outline-danger"
                            data-mt-swal-message="Reset all settings to default values?"
                            data-mt-swal-title="Reset settings"
                            data-mt-swal-icon="warning"
                            data-mt-swal-confirm-text="Reset"
                            data-mt-swal-success="Settings reset to defaults">
                        <i class="bi bi-arrow-counterclockwise me-1"></i>Reset Defaults
                    </button>
                    <button type="submit" class="btn btn-primary btn-lg">
                        <i class="bi bi-save me-1"></i>Save Settings
                    </button>
                </div>
            </form>
        </div>

        <!-- Sidebar Info -->
        <div class="col-lg-4">
            <div class="card mb-4">
                <div class="card-header bg-white">
                    <h5 class="fw-bold mb-0"><i class="bi bi-info-circle me-2"></i>System Info</h5>
                </div>
                <div class="card-body">
                    <div class="mb-2 d-flex justify-content-between">
                        <span class="text-muted">Version</span>
                        <span class="fw-bold">1.0.0</span>
                    </div>
                    <div class="mb-2 d-flex justify-content-between">
                        <span class="text-muted">Framework</span>
                        <span class="fw-bold">ASP.NET Core 8.0</span>
                    </div>
                    <div class="mb-2 d-flex justify-content-between">
                        <span class="text-muted">Database</span>
                        <span class="fw-bold">SQL Server 2022</span>
                    </div>
                    <div class="mb-2 d-flex justify-content-between">
                        <span class="text-muted">Last Deployed</span>
                        <span class="fw-bold">Jun 06, 2026</span>
                    </div>
                    <div class="mb-0 d-flex justify-content-between">
                        <span class="text-muted">Environment</span>
                        <span class="badge bg-success">Production</span>
                    </div>
                </div>
            </div>

            <div class="card">
                <div class="card-header bg-white">
                    <h5 class="fw-bold mb-0"><i class="bi bi-shield-check me-2"></i>Security Status</h5>
                </div>
                <div class="card-body">
                    <div class="mb-2 d-flex justify-content-between align-items-center">
                        <span class="text-muted">HTTPS</span>
                        <span class="badge bg-success">Enabled</span>
                    </div>
                    <div class="mb-2 d-flex justify-content-between align-items-center">
                        <span class="text-muted">2FA</span>
                        <span class="badge bg-warning text-dark">Optional</span>
                    </div>
                    <div class="mb-2 d-flex justify-content-between align-items-center">
                        <span class="text-muted">Password Policy</span>
                        <span class="badge bg-success">Strong</span>
                    </div>
                    <div class="mb-0 d-flex justify-content-between align-items-center">
                        <span class="text-muted">Audit Logging</span>
                        <span class="badge bg-success">Active</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>