@{
    ViewData["Title"] = "Add Drug";
    ViewData["PageIcon"] = "bi-capsule-pill";
    ViewData["Subtitle"] = "Add a medication to the national catalog";
    ViewData["BackUrl"] = "/Admin/Drugs";
}

<div class="fade-in">
    <partial name="_PageHeader" />

    <div class="row justify-content-center">
        <div class="col-lg-7">
            <div class="card">
                <div class="card-body p-4">
                    <form method="post" asp-action="AddDrug">
                        @Html.AntiForgeryToken()
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Generic Name</label>
                            <input name="GenericName" class="form-control" required />
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Brand Names</label>
                            <input name="BrandNames" class="form-control" placeholder="e.g. Panadol, Tylenol" />
                        </div>
                        <div class="row">
                            <div class="col-md-4 mb-3">
                                <label class="form-label fw-semibold">Category</label>
                                <input name="Category" class="form-control" />
                            </div>
                            <div class="col-md-4 mb-3">
                                <label class="form-label fw-semibold">Default Unit</label>
                                <input name="DefaultUnit" class="form-control" placeholder="Tablets" />
                            </div>
                            <div class="col-md-4 mb-3">
                                <label class="form-label fw-semibold">Min Stock Level</label>
                                <input name="DefaultMinStockLevel" type="number" min="0" class="form-control" value="10" />
                            </div>
                        </div>
                        <div class="form-check form-switch mb-2">
                            <input class="form-check-input" type="checkbox" name="IsCritical" id="isCritical" />
                            <label class="form-check-label" for="isCritical">Critical medication</label>
                        </div>
                        <div class="form-check form-switch mb-4">
                            <input class="form-check-input" type="checkbox" name="RequiresPrescription" id="rx" />
                            <label class="form-check-label" for="rx">Requires prescription</label>
                        </div>
                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg me-1"></i>Add Drug</button>
                            <a href="/Admin/Drugs" class="btn btn-outline-secondary">Cancel</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
