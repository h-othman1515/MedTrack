@model MedTrack.Models.ViewModels.AdminDashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
    Layout = "_Layout";
}

<div class="fade-in">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-1"><i class="bi bi-grid me-2"></i>Dashboard</h2>
            <p class="text-muted mb-0">Platform management, user oversight, and system configuration</p>
        </div>
        <div class="d-flex gap-2">
            <a href="/Admin/AuditLogs" class="btn btn-outline-dark">
                <i class="bi bi-journal-text me-1"></i>Audit Logs
            </a>
            <a href="/Admin/Settings" class="btn btn-primary">
                <i class="bi bi-gear me-1"></i>Settings
            </a>
        </div>
    </div>

    <!-- System Stats Row -->
    <div class="row g-3 mb-4">
        <div class="col-xl-2 col-md-4 col-6">
            <div class="card stat-card primary">
                <div class="card-body text-center">
                    <div class="stat-icon bg-primary bg-opacity-10 text-primary mx-auto mb-2" style="width: 40px; height: 40px; font-size: 1.2rem;">
                        <i class="bi bi-people"></i>
                    </div>
                    <h4 class="fw-bold mb-0">@Model.TotalUsers</h4>
                    <small class="text-muted">Total Users</small>
                </div>
            </div>
        </div>
        <div class="col-xl-2 col-md-4 col-6">
            <div class="card stat-card success">
                <div class="card-body text-center">
                    <div class="stat-icon bg-success bg-opacity-10 text-success mx-auto mb-2" style="width: 40px; height: 40px; font-size: 1.2rem;">
                        <i class="bi bi-shop"></i>
                    </div>
                    <h4 class="fw-bold mb-0">@Model.ActivePharmacies</h4>
                    <small class="text-muted">Active Pharmacies</small>
                </div>
            </div>
        </div>
        <div class="col-xl-2 col-md-4 col-6">
            <div class="card stat-card warning">
                <div class="card-body text-center">
                    <div class="stat-icon bg-warning bg-opacity-10 text-warning mx-auto mb-2" style="width: 40px; height: 40px; font-size: 1.2rem;">
                        <i class="bi bi-hourglass-split"></i>
                    </div>
                    <h4 class="fw-bold mb-0">@Model.PendingApprovals</h4>
                    <small class="text-muted">Pending Approvals</small>
                </div>
            </div>
        </div>
        <div class="col-xl-2 col-md-4 col-6">
            <div class="card stat-card info">
                <div class="card-body text-center">
                    <div class="stat-icon bg-info bg-opacity-10 text-info mx-auto mb-2" style="width: 40px; height: 40px; font-size: 1.2rem;">
                        <i class="bi bi-capsule"></i>
                    </div>
                    <h4 class="fw-bold mb-0">@Model.TotalDrugs</h4>
                    <small class="text-muted">Drug Catalog</small>
                </div>
            </div>
        </div>
        <div class="col-xl-2 col-md-4 col-6">
            <div class="card stat-card danger">
                <div class="card-body text-center">
                    <div class="stat-icon bg-danger bg-opacity-10 text-danger mx-auto mb-2" style="width: 40px; height: 40px; font-size: 1.2rem;">
                        <i class="bi bi-exclamation-triangle"></i>
                    </div>
                    <h4 class="fw-bold mb-0">@Model.ActiveAlerts</h4>
                    <small class="text-muted">Active Alerts</small>
                </div>
            </div>
        </div>
        <div class="col-xl-2 col-md-4 col-6">
            <div class="card stat-card orange">
                <div class="card-body text-center">
                    <div class="stat-icon bg-orange bg-opacity-10 text-orange mx-auto mb-2" style="width: 40px; height: 40px; font-size: 1.2rem; background: rgba(255,121,0,0.1); color: #ff7900;">
                        <i class="bi bi-arrow-left-right"></i>
                    </div>
                    <h4 class="fw-bold mb-0">@Model.TotalTransfers</h4>
                    <small class="text-muted">Transfers</small>
                </div>
            </div>
        </div>
    </div>

    <!-- Quick Action Cards -->
    <div class="row g-4 mb-4">
        <div class="col-lg-3 col-md-6">
            <a href="/Admin/Users" class="card text-decoration-none h-100 border-primary hover-shadow">
                <div class="card-body d-flex align-items-center">
                    <div class="bg-primary bg-opacity-10 text-primary rounded-3 p-3 me-3">
                        <i class="bi bi-people fs-3"></i>
                    </div>
                    <div>
                        <h5 class="fw-bold mb-1 text-dark">User Management</h5>
                        <p class="text-muted small mb-0">Manage accounts, roles, and permissions</p>
                    </div>
                </div>
            </a>
        </div>
        <div class="col-lg-3 col-md-6">
            <a href="/Admin/Pharmacies" class="card text-decoration-none h-100 border-success hover-shadow">
                <div class="card-body d-flex align-items-center">
                    <div class="bg-success bg-opacity-10 text-success rounded-3 p-3 me-3">
                        <i class="bi bi-shop fs-3"></i>
                    </div>
                    <div>
                        <h5 class="fw-bold mb-1 text-dark">Pharmacies</h5>
                        <p class="text-muted small mb-0">Approve, suspend, and manage pharmacies</p>
                    </div>
                </div>
            </a>
        </div>
        <div class="col-lg-3 col-md-6">
            <a href="/Admin/Drugs" class="card text-decoration-none h-100 border-info hover-shadow">
                <div class="card-body d-flex align-items-center">
                    <div class="bg-info bg-opacity-10 text-info rounded-3 p-3 me-3">
                        <i class="bi bi-capsule fs-3"></i>
                    </div>
                    <div>
                        <h5 class="fw-bold mb-1 text-dark">Drug Catalog</h5>
                        <p class="text-muted small mb-0">Manage master drug list and categories</p>
                    </div>
                </div>
            </a>
        </div>
        <div class="col-lg-3 col-md-6">
            <a href="/Admin/Notifications" class="card text-decoration-none h-100 border-warning hover-shadow">
                <div class="card-body d-flex align-items-center">
                    <div class="bg-warning bg-opacity-10 text-warning rounded-3 p-3 me-3">
                        <i class="bi bi-broadcast fs-3"></i>
                    </div>
                    <div>
                        <h5 class="fw-bold mb-1 text-dark">Broadcast</h5>
                        <p class="text-muted small mb-0">Send system-wide alerts and notifications</p>
                    </div>
                </div>
            </a>
        </div>
    </div>

    <div class="row g-4">
        <!-- Pending Approvals -->
        <div class="col-lg-6">
            <div class="card h-100">
                <div class="card-header bg-white d-flex justify-content-between align-items-center">
                    <h5 class="fw-bold mb-0"><i class="bi bi-hourglass-split me-2 text-warning"></i>Pending Pharmacy Approvals</h5>
                    <a href="/Admin/Pharmacies?filter=pending" class="btn btn-sm btn-outline-primary">View All</a>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-medtrack mb-0">
                            <thead>
                                <tr>
                                    <th>Pharmacy</th>
                                    <th>License</th>
                                    <th>Governorate</th>
                                    <th>Registered</th>
                                    <th>Action</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var pharmacy in Model.PendingPharmacies)
                                {
                                    <tr>
                                        <td>
                                            <div class="fw-bold">@pharmacy.Name</div>
                                            <small class="text-muted">@pharmacy.ManagerName</small>
                                        </td>
                                        <td><code>@pharmacy.LicenseNo</code></td>
                                        <td>@pharmacy.Governorate</td>
                                        <td>@pharmacy.RegisteredAt.ToString("MMM dd")</td>
                                        <td>
                                            <div class="btn-group btn-group-sm">
                                                <button type="button" class="btn btn-success"
                                                        data-mt-swal-message="Approve this pharmacy registration?"
                                                        data-mt-swal-title="Approve pharmacy"
                                                        data-mt-swal-icon="question"
                                                        data-mt-swal-confirm-text="Approve"
                                                        data-mt-swal-success="Pharmacy approved successfully"
                                                        data-bs-toggle="tooltip" title="Approve">
                                                    <i class="bi bi-check-lg"></i>
                                                </button>
                                                <button type="button" class="btn btn-danger"
                                                        data-mt-swal-message="Reject this pharmacy registration? This action cannot be undone."
                                                        data-mt-swal-title="Reject pharmacy"
                                                        data-mt-swal-icon="warning"
                                                        data-mt-swal-danger="true"
                                                        data-mt-swal-confirm-text="Reject"
                                                        data-mt-swal-success="Pharmacy rejected"
                                                        data-mt-swal-success-type="warning"
                                                        data-bs-toggle="tooltip" title="Reject">
                                                    <i class="bi bi-x-lg"></i>
                                                </button>
                                                <a href="/Admin/PharmacyDetails/@pharmacy.Id" class="btn btn-outline-secondary" data-bs-toggle="tooltip" title="Details">
                                                    <i class="bi bi-eye"></i>
                                                </a>
                                            </div>
                                        </td>
                                    </tr>
                                }
                                @if (!Model.PendingPharmacies.Any())
                                {
                                    @foreach (var demo in new[] {
                                        new { Id = 1, Name = "Al-Noor Pharmacy", Manager = "Ahmad Khalil", License = "MOH-2026-00142", Gov = "Amman", Date = DateTime.Now.AddDays(-2) },
                                        new { Id = 2, Name = "Irbid Care Center", Manager = "Sara Nasser", License = "MOH-2026-00143", Gov = "Irbid", Date = DateTime.Now.AddDays(-1) },
                                        new { Id = 3, Name = "Zarqa Health Plus", Manager = "Omar Haddad", License = "MOH-2026-00144", Gov = "Zarqa", Date = DateTime.Now.AddHours(-12) }
                                    })
                                    {
                                        <tr>
                                            <td>
                                                <div class="fw-bold">@demo.Name</div>
                                                <small class="text-muted">@demo.Manager</small>
                                            </td>
                                            <td><code>@demo.License</code></td>
                                            <td>@demo.Gov</td>
                                            <td>@demo.Date.ToString("MMM dd")</td>
                                            <td>
                                                <div class="btn-group btn-group-sm">
                                                    <button type="button" class="btn btn-success"
                                                            data-mt-swal-message="Approve this pharmacy registration?"
                                                            data-mt-swal-title="Approve pharmacy"
                                                            data-mt-swal-icon="question"
                                                            data-mt-swal-confirm-text="Approve"
                                                            data-mt-swal-success="Pharmacy approved successfully"
                                                            data-bs-toggle="tooltip" title="Approve">
                                                        <i class="bi bi-check-lg"></i>
                                                    </button>
                                                    <button type="button" class="btn btn-danger"
                                                            data-mt-swal-message="Reject this pharmacy registration? This action cannot be undone."
                                                            data-mt-swal-title="Reject pharmacy"
                                                            data-mt-swal-icon="warning"
                                                            data-mt-swal-danger="true"
                                                            data-mt-swal-confirm-text="Reject"
                                                            data-mt-swal-success="Pharmacy rejected"
                                                            data-mt-swal-success-type="warning"
                                                            data-bs-toggle="tooltip" title="Reject">
                                                        <i class="bi bi-x-lg"></i>
                                                    </button>
                                                    <a href="/Admin/PharmacyDetails/@demo.Id" class="btn btn-outline-secondary" data-bs-toggle="tooltip" title="Details">
                                                        <i class="bi bi-eye"></i>
                                                    </a>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <!-- Recent System Activity -->
        <div class="col-lg-6">
            <div class="card h-100">
                <div class="card-header bg-white d-flex justify-content-between align-items-center">
                    <h5 class="fw-bold mb-0"><i class="bi bi-activity me-2 text-primary"></i>Recent System Activity</h5>
                    <a href="/Admin/AuditLogs" class="btn btn-sm btn-outline-primary">View Logs</a>
                </div>
                <div class="card-body p-0">
                    <div class="list-group list-group-flush">
                        @foreach (var log in Model.RecentActivity)
                        {
                            <div class="list-group-item p-3">
                                <div class="d-flex">
                                    <div class="bg-@(log.Type == "User" ? "primary" : log.Type == "Pharmacy" ? "success" : log.Type == "Alert" ? "danger" : "info") bg-opacity-10 text-@(log.Type == "User" ? "primary" : log.Type == "Pharmacy" ? "success" : log.Type == "Alert" ? "danger" : "info") rounded-3 p-2 me-3" style="width: 36px; height: 36px; display: flex; align-items: center; justify-content: center;">
                                        <i class="bi bi-@(log.Type == "User" ? "person" : log.Type == "Pharmacy" ? "shop" : log.Type == "Alert" ? "bell" : "arrow-left-right")"></i>
                                    </div>
                                    <div class="flex-grow-1">
                                        <div class="d-flex justify-content-between">
                                            <span class="fw-bold small">@log.Action</span>
                                            <small class="text-muted">@log.Timestamp.ToString("HH:mm")</small>
                                        </div>
                                        <p class="small text-muted mb-0">@log.Details</p>
                                        <small class="text-muted">by @log.PerformedBy</small>
                                    </div>
                                </div>
                            </div>
                        }
                        @if (!Model.RecentActivity.Any())
                        {
                            @foreach (var demo in new[] {
                                new { Type = "Pharmacy", Action = "Pharmacy Approved", Details = "Al-Noor Pharmacy approved by admin", PerformedBy = "Admin", Time = DateTime.Now.AddMinutes(-5) },
                                new { Type = "User", Action = "User Registered", Details = "New pharmacy manager account created", PerformedBy = "System", Time = DateTime.Now.AddMinutes(-15) },
                                new { Type = "Alert", Action = "SOS Alert Triggered", Details = "Insulin shortage SOS sent to 12 pharmacies", PerformedBy = "Al-Shifa Pharmacy", Time = DateTime.Now.AddMinutes(-30) },
                                new { Type = "Transfer", Action = "Transfer Completed", Details = "Transfer #1024 marked complete", PerformedBy = "Zarqa Central", Time = DateTime.Now.AddHours(-1) },
                                new { Type = "User", Action = "Role Changed", Details = "Pharmacy Staff promoted to Manager", PerformedBy = "Admin", Time = DateTime.Now.AddHours(-2) }
                            })
                            {
                                <div class="list-group-item p-3">
                                    <div class="d-flex">
                                        <div class="bg-@(demo.Type == "User" ? "primary" : demo.Type == "Pharmacy" ? "success" : demo.Type == "Alert" ? "danger" : "info") bg-opacity-10 text-@(demo.Type == "User" ? "primary" : demo.Type == "Pharmacy" ? "success" : demo.Type == "Alert" ? "danger" : "info") rounded-3 p-2 me-3" style="width: 36px; height: 36px; display: flex; align-items: center; justify-content: center;">
                                            <i class="bi bi-@(demo.Type == "User" ? "person" : demo.Type == "Pharmacy" ? "shop" : demo.Type == "Alert" ? "bell" : "arrow-left-right")"></i>
                                        </div>
                                        <div class="flex-grow-1">
                                            <div class="d-flex justify-content-between">
                                                <span class="fw-bold small">@demo.Action</span>
                                                <small class="text-muted">@demo.Time.ToString("HH:mm")</small>
                                            </div>
                                            <p class="small text-muted mb-0">@demo.Details</p>
                                            <small class="text-muted">by @demo.PerformedBy</small>
                                        </div>
                                    </div>
                                </div>
                            }
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- System Health -->
    <div class="row g-4 mt-1">
        <div class="col-lg-4">
            <div class="card">
                <div class="card-header bg-white">
                    <h5 class="fw-bold mb-0"><i class="bi bi-heart-pulse me-2 text-danger"></i>System Health</h5>
                </div>
                <div class="card-body">
                    <div class="mb-3">
                        <div class="d-flex justify-content-between mb-1">
                            <span class="small">Database</span>
                            <span class="small text-success fw-bold">Healthy</span>
                        </div>
                        <div class="progress progress-thin">
                            <div class="progress-bar bg-success" style="width: 100%"></div>
                        </div>
                    </div>
                    <div class="mb-3">
                        <div class="d-flex justify-content-between mb-1">
                            <span class="small">SMS Service (Orange)</span>
                            <span class="small text-success fw-bold">Operational</span>
                        </div>
                        <div class="progress progress-thin">
                            <div class="progress-bar bg-success" style="width: 98%"></div>
                        </div>
                    </div>
                    <div class="mb-3">
                        <div class="d-flex justify-content-between mb-1">
                            <span class="small">Email Service (SendGrid)</span>
                            <span class="small text-success fw-bold">Operational</span>
                        </div>
                        <div class="progress progress-thin">
                            <div class="progress-bar bg-success" style="width: 100%"></div>
                        </div>
                    </div>
                    <div class="mb-3">
                        <div class="d-flex justify-content-between mb-1">
                            <span class="small">Background Jobs</span>
                            <span class="small text-warning fw-bold">1 Warning</span>
                        </div>
                        <div class="progress progress-thin">
                            <div class="progress-bar bg-warning" style="width: 85%"></div>
                        </div>
                    </div>
                    <div class="mb-0">
                        <div class="d-flex justify-content-between mb-1">
                            <span class="small">API Response Time</span>
                            <span class="small text-success fw-bold">42ms avg</span>
                        </div>
                        <div class="progress progress-thin">
                            <div class="progress-bar bg-success" style="width: 95%"></div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card">
                <div class="card-header bg-white">
                    <h5 class="fw-bold mb-0"><i class="bi bi-envelope me-2 text-primary"></i>Notification Volume</h5>
                </div>
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <span class="small">SMS Sent Today</span>
                        <span class="fw-bold">@Model.SmsSentToday</span>
                    </div>
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <span class="small">Emails Sent Today</span>
                        <span class="fw-bold">@Model.EmailsSentToday</span>
                    </div>
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <span class="small">In-App Notifications</span>
                        <span class="fw-bold">@Model.InAppNotificationsToday</span>
                    </div>
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <span class="small">Failed Deliveries</span>
                        <span class="fw-bold text-danger">@Model.FailedDeliveries</span>
                    </div>
                    <div class="d-flex justify-content-between align-items-center mb-0">
                        <span class="small">Success Rate</span>
                        <span class="fw-bold text-success">@Model.NotificationSuccessRate%</span>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card">
                <div class="card-header bg-white">
                    <h5 class="fw-bold mb-0"><i class="bi bi-cash-stack me-2 text-success"></i>Platform Metrics</h5>
                </div>
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <span class="small">Total Inventory Value</span>
                        <span class="fw-bold">@Model.TotalInventoryValue.ToString("C0") JOD</span>
                    </div>
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <span class="small">Waste Prevented (Month)</span>
                        <span class="fw-bold text-success">@Model.WastePreventedMonth.ToString("C0") JOD</span>
                    </div>
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <span class="small">Active Subscriptions</span>
                        <span class="fw-bold">@Model.ActiveSubscriptions</span>
                    </div>
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <span class="small">Revenue (Month)</span>
                        <span class="fw-bold">@Model.MonthlyRevenue.ToString("C0") JOD</span>
                    </div>
                    <div class="d-flex justify-content-between align-items-center mb-0">
                        <span class="small">Avg. Pharmacy Uptime</span>
                        <span class="fw-bold">@Model.AvgPharmacyUptime%</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>