@model MedTrack.Models.ViewModels.AdminDashboardViewModel
@using System.Security.Claims
@{
    ViewData["Title"] = "Dashboard";
    Layout = "_Layout";

    var userName = User.Identity?.Name ?? "Admin";
    var hour = DateTime.Now.Hour;
    var greeting = hour < 12 ? "Good morning" : hour < 17 ? "Good afternoon" : "Good evening";
}

<div class="fade-in">

    <!-- ?? Header ?? -->
    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
        <div>
            <h2 class="fw-bold mb-1"><i class="bi bi-grid me-2"></i>@greeting, @userName.Split('@')[0] ??</h2>
            <p class="text-muted mb-0">Platform management, user oversight, and system configuration</p>
        </div>
        <div class="d-flex gap-2">
            <a href="/Admin/AuditLogs" class="btn btn-outline-secondary">
                <i class="bi bi-journal-text me-1"></i>Audit Logs
            </a>
            <a href="/Admin/Settings" class="btn btn-primary">
                <i class="bi bi-gear me-1"></i>Settings
            </a>
        </div>
    </div>

    <!-- ?? System Stats Row ?? -->
    <div class="row g-3 mb-4">
        <div class="col-xl-2 col-md-4 col-6">
            <div class="card stat-card primary text-center py-3">
                <div class="stat-icon bg-primary bg-opacity-10 text-primary mx-auto mb-2">
                    <i class="bi bi-people"></i>
                </div>
                <h4 class="fw-bold mb-0">@Model.TotalUsers</h4>
                <small class="text-muted">Total Users</small>
            </div>
        </div>
        <div class="col-xl-2 col-md-4 col-6">
            <div class="card stat-card success text-center py-3">
                <div class="stat-icon bg-success bg-opacity-10 text-success mx-auto mb-2">
                    <i class="bi bi-shop"></i>
                </div>
                <h4 class="fw-bold mb-0">@Model.ActivePharmacies</h4>
                <small class="text-muted">Active Pharmacies</small>
            </div>
        </div>
        <div class="col-xl-2 col-md-4 col-6">
            <div class="card stat-card warning text-center py-3">
                <div class="stat-icon bg-warning bg-opacity-10 text-warning mx-auto mb-2">
                    <i class="bi bi-hourglass-split"></i>
                </div>
                <h4 class="fw-bold mb-0">@Model.PendingApprovals</h4>
                <small class="text-muted">Pending Approvals</small>
            </div>
        </div>
        <div class="col-xl-2 col-md-4 col-6">
            <div class="card stat-card info text-center py-3">
                <div class="stat-icon bg-info bg-opacity-10 text-info mx-auto mb-2">
                    <i class="bi bi-capsule"></i>
                </div>
                <h4 class="fw-bold mb-0">@Model.TotalDrugs</h4>
                <small class="text-muted">Drug Catalog</small>
            </div>
        </div>
        <div class="col-xl-2 col-md-4 col-6">
            <div class="card stat-card danger text-center py-3">
                <div class="stat-icon bg-danger bg-opacity-10 text-danger mx-auto mb-2">
                    <i class="bi bi-exclamation-triangle"></i>
                </div>
                <h4 class="fw-bold mb-0">@Model.ActiveAlerts</h4>
                <small class="text-muted">Active Alerts</small>
            </div>
        </div>
        <div class="col-xl-2 col-md-4 col-6">
            <div class="card text-center py-3">
                <div class="stat-icon mx-auto mb-2" style="background:rgba(255,121,0,0.1);color:#ff7900;">
                    <i class="bi bi-arrow-left-right"></i>
                </div>
                <h4 class="fw-bold mb-0">@Model.TotalTransfers</h4>
                <small class="text-muted">Transfers</small>
            </div>
        </div>
    </div>

    <!-- ?? Quick Actions ?? -->
    <div class="row g-3 mb-4">
        <div class="col-lg-3 col-md-6">
            <a href="/Admin/Users" class="card text-decoration-none h-100 border-primary hover-shadow">
                <div class="card-body d-flex align-items-center gap-3">
                    <div class="bg-primary bg-opacity-10 text-primary rounded-3 p-3">
                        <i class="bi bi-people fs-3"></i>
                    </div>
                    <div>
                        <h6 class="fw-bold mb-1">User Management</h6>
                        <p class="text-muted small mb-0">Accounts, roles & permissions</p>
                    </div>
                </div>
            </a>
        </div>
        <div class="col-lg-3 col-md-6">
            <a href="/Admin/Pharmacies" class="card text-decoration-none h-100 border-success hover-shadow">
                <div class="card-body d-flex align-items-center gap-3">
                    <div class="bg-success bg-opacity-10 text-success rounded-3 p-3">
                        <i class="bi bi-shop fs-3"></i>
                    </div>
                    <div>
                        <h6 class="fw-bold mb-1">Pharmacies</h6>
                        <p class="text-muted small mb-0">Approve, suspend & manage</p>
                    </div>
                </div>
            </a>
        </div>
        <div class="col-lg-3 col-md-6">
            <a href="/Admin/Drugs" class="card text-decoration-none h-100 border-info hover-shadow">
                <div class="card-body d-flex align-items-center gap-3">
                    <div class="bg-info bg-opacity-10 text-info rounded-3 p-3">
                        <i class="bi bi-capsule fs-3"></i>
                    </div>
                    <div>
                        <h6 class="fw-bold mb-1">Drug Catalog</h6>
                        <p class="text-muted small mb-0">Master drug list & categories</p>
                    </div>
                </div>
            </a>
        </div>
        <div class="col-lg-3 col-md-6">
            <a href="/Admin/Notifications" class="card text-decoration-none h-100 border-warning hover-shadow">
                <div class="card-body d-flex align-items-center gap-3">
                    <div class="bg-warning bg-opacity-10 text-warning rounded-3 p-3">
                        <i class="bi bi-broadcast fs-3"></i>
                    </div>
                    <div>
                        <h6 class="fw-bold mb-1">Broadcast</h6>
                        <p class="text-muted small mb-0">System-wide alerts & notifications</p>
                    </div>
                </div>
            </a>
        </div>
    </div>

    <!-- ?? Pending Approvals + Recent Activity ?? -->
    <div class="row g-4 mb-4">
        <div class="col-lg-6">
            <div class="card h-100">
                <div class="card-header bg-transparent d-flex justify-content-between align-items-center">
                    <h5 class="fw-bold mb-0"><i class="bi bi-hourglass-split me-2 text-warning"></i>Pending Pharmacy Approvals</h5>
                    <a href="/Admin/Pharmacies?filter=pending" class="btn btn-sm btn-outline-primary">View All</a>
                </div>
                <div class="card-body border-bottom py-3">
                    <div class="row g-2">
                        <div class="col-md-8">
                            <div class="input-group input-group-sm">
                                <span class="input-group-text"><i class="bi bi-search"></i></span>
                                <input type="text" class="form-control" id="searchPending" placeholder="Search pending...">
                            </div>
                        </div>
                        <div class="col-md-4">
                            <button class="btn btn-outline-secondary btn-sm w-100" onclick="resetPendingFilters()">Reset Filters</button>
                        </div>
                    </div>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-medtrack mb-0" id="pendingPharmaciesTable">
                            <thead>
                                <tr>
                                    <th>Pharmacy</th>
                                    <th>License</th>
                                    <th>Governorate</th>
                                    <th>Registered</th>
                                    <th>Action</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var pharmacy in Model.PendingPharmacies)
                                {
                                    <tr data-governorate="@pharmacy.Governorate">
                                        <td>
                                            <div class="fw-bold">@pharmacy.Name</div>
                                            <small class="text-muted">@pharmacy.ManagerName</small>
                                        </td>
                                        <td><code>@pharmacy.LicenseNo</code></td>
                                        <td>@pharmacy.Governorate</td>
                                        <td>@pharmacy.RegisteredAt.ToString("MMM dd")</td>
                                        <td>
                                            <div class="btn-group btn-group-sm">
                                                <form asp-action="ApprovePharmacy" method="post" class="d-inline">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="id" value="@pharmacy.Id" />
                                                    <input type="hidden" name="returnUrl" value="@Url.Action("Index")" />
                                                    <button type="button" class="btn btn-success"
                                                            data-mt-swal-message="Approve this pharmacy registration?"
                                                            data-mt-swal-title="Approve pharmacy"
                                                            data-mt-swal-icon="question"
                                                            data-mt-swal-confirm-text="Approve"
                                                            title="Approve">
                                                        <i class="bi bi-check-lg"></i>
                                                    </button>
                                                </form>
                                                <form asp-action="RejectPharmacy" method="post" class="d-inline">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="id" value="@pharmacy.Id" />
                                                    <input type="hidden" name="returnUrl" value="@Url.Action("Index")" />
                                                    <button type="button" class="btn btn-danger"
                                                            data-mt-swal-message="Reject this pharmacy registration? This action cannot be undone."
                                                            data-mt-swal-title="Reject pharmacy"
                                                            data-mt-swal-icon="warning"
                                                            data-mt-swal-danger="true"
                                                            data-mt-swal-confirm-text="Reject"
                                                            title="Reject">
                                                        <i class="bi bi-x-lg"></i>
                                                    </button>
                                                </form>
                                                <a href="/Admin/PharmacyDetails/@pharmacy.Id" class="btn btn-outline-secondary" title="Details">
                                                    <i class="bi bi-eye"></i>
                                                </a>
                                            </div>
                                        </td>
                                    </tr>
                                }
                                @if (!Model.PendingPharmacies.Any())
                                {
                                    <tr>
                                        <td colspan="5" class="text-center py-5 text-muted">
                                            <i class="bi bi-inbox fs-1 d-block mb-2"></i>
                                            All pharmacies approved ? nothing pending.
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
                <div class="card-footer bg-transparent">
                    <span class="text-muted small" id="pendingRowCount">Showing @Model.PendingPharmacies.Count items</span>
                </div>
            </div>
        </div>

        <!-- Recent System Activity -->
        <div class="col-lg-6">
            <div class="card h-100">
                <div class="card-header bg-transparent d-flex justify-content-between align-items-center">
                    <h5 class="fw-bold mb-0"><i class="bi bi-activity me-2 text-primary"></i>Recent System Activity</h5>
                    <a href="/Admin/AuditLogs" class="btn btn-sm btn-outline-primary">View Logs</a>
                </div>
                <div class="card-body p-0">
                    <div class="list-group list-group-flush">
                        @foreach (var log in Model.RecentActivity)
                        {
                            
                                var logColor = log.Type == "User" ? "primary" : log.Type == "Pharmacy" ? "success" : log.Type == "Alert" ? "danger" : "info";
                                var logIcon  = log.Type == "User" ? "person" : log.Type == "Pharmacy" ? "shop" : log.Type == "Alert" ? "bell" : "arrow-left-right";
                            
                            <div class="list-group-item p-3">
                                <div class="d-flex gap-3">
                                    <div class="bg-@logColor bg-opacity-10 text-@logColor rounded-3 p-2 flex-shrink-0 d-flex align-items-center justify-content-center" style="width:36px;height:36px;">
                                        <i class="bi bi-@logIcon"></i>
                                    </div>
                                    <div class="flex-grow-1">
                                        <div class="d-flex justify-content-between">
                                            <span class="fw-bold small">@log.Action</span>
                                            <small class="text-muted">@log.Timestamp.ToString("HH:mm")</small>
                                        </div>
                                        <p class="small text-muted mb-0">@log.Details</p>
                                        <small class="text-muted">by @log.PerformedBy</small>
                                    </div>
                                </div>
                            </div>
                        }
                        @if (!Model.RecentActivity.Any())
                        {
                            <div class="list-group-item p-4 text-center text-muted">
                                <i class="bi bi-clock-history fs-3 d-block mb-2"></i>
                                No recent activity recorded.
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- ?? System Health + Notification Volume + Platform Metrics ?? -->
    <div class="row g-4">
        <div class="col-lg-4">
            <div class="card">
                <div class="card-header bg-transparent">
                    <h5 class="fw-bold mb-0"><i class="bi bi-heart-pulse me-2 text-danger"></i>System Health</h5>
                </div>
                <div class="card-body">
                    @{
                        var healthItems = new[]
                        {
                            ("Database",              "Healthy",     "success", 100),
                            ("SMS Service (Orange)",  "Operational", "success", 98),
                            ("Email (SendGrid)",      "Operational", "success", 100),
                            ("Background Jobs",       "1 Warning",   "warning", 85),
                            ("API Response Time",     "42ms avg",    "success", 95),
                        };
                    }
                    @foreach (var (label, status, color, pct) in healthItems)
                    {
                        <div class="mb-3">
                            <div class="d-flex justify-content-between mb-1">
                                <span class="small">@label</span>
                                <span class="small text-@color fw-bold">@status</span>
                            </div>
                            <div class="progress progress-thin">
                                <div class="progress-bar bg-@color" style="width:@pct%"></div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card">
                <div class="card-header bg-transparent">
                    <h5 class="fw-bold mb-0"><i class="bi bi-envelope me-2 text-primary"></i>Notification Volume</h5>
                </div>
                <div class="card-body">
                    @{
                        var notifItems = new (string Label, string Value, string Color)[]
                        {
                            ("SMS Sent Today",        Model.SmsSentToday.ToString(),              ""),
                            ("Emails Sent Today",     Model.EmailsSentToday.ToString(),           ""),
                            ("In-App Notifications",  Model.InAppNotificationsToday.ToString(),   ""),
                            ("Failed Deliveries",     Model.FailedDeliveries.ToString(),          "danger"),
                            ("Success Rate",          Model.NotificationSuccessRate + "%",        "success"),
                        };
                    }
                    @foreach (var (label, value, color) in notifItems)
                    {
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <span class="small">@label</span>
                            <span class="fw-bold @(color != "" ? "text-" + color : "")">@value</span>
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card">
                <div class="card-header bg-transparent">
                    <h5 class="fw-bold mb-0"><i class="bi bi-cash-stack me-2 text-success"></i>Platform Metrics</h5>
                </div>
                <div class="card-body">
                    @{
                        var metricItems = new (string Label, string Value, string Color)[]
                        {
                            ("Total Inventory Value",    Model.TotalInventoryValue.ToString("C0") + " JOD", ""),
                            ("Waste Prevented (Month)",  Model.WastePreventedMonth.ToString("C0") + " JOD", "success"),
                            ("Active Subscriptions",     Model.ActiveSubscriptions.ToString(),               ""),
                            ("Revenue (Month)",          Model.MonthlyRevenue.ToString("C0") + " JOD",       ""),
                            ("Avg. Pharmacy Uptime",     Model.AvgPharmacyUptime + "%",                      ""),
                        };
                    }
                    @foreach (var (label, value, color) in metricItems)
                    {
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <span class="small">@label</span>
                            <span class="fw-bold @(color != "" ? "text-" + color : "")">@value</span>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function filterPendingRows() {
            var search = $('#searchPending').val().toLowerCase();
            var visible = 0;

            $('#pendingPharmaciesTable tbody tr').each(function () {
                var $row = $(this);
                if ($row.find('td[colspan]').length) return;

                var text = $row.text().toLowerCase();
                var show = !search || text.indexOf(search) !== -1;
                $row.toggle(show);
                if (show) visible++;
            });

            $('#pendingRowCount').text('Showing ' + visible + ' items');
        }

        function resetPendingFilters() {
            $('#searchPending').val('');
            $('#pendingPharmaciesTable tbody tr').show();
            $('#pendingRowCount').text('Showing @Model.PendingPharmacies.Count items');
        }

        $('#searchPending').on('keyup', filterPendingRows);
    </script>
}