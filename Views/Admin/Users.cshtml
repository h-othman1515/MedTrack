@model MedTrack.Models.ViewModels.UserManagementViewModel
@{
    ViewData["Title"] = "User Management";
    Layout = "_Layout";
    var users = Model.Users;
    var active = users.Count(u => u.Status == "Active");
    var suspended = users.Count(u => u.Status == "Suspended");
    var pending = users.Count(u => u.Status == "Pending");
}

<div class="fade-in">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-1"><i class="bi bi-people me-2"></i>User Management</h2>
            <p class="text-muted mb-0">Manage accounts, roles, and access permissions</p>
        </div>
        <div class="d-flex gap-2">
            <button class="btn btn-outline-secondary" onclick="exportTableToCSV('usersTable', 'users.csv')">
                <i class="bi bi-download me-1"></i>Export
            </button>
            <a href="/Admin/CreateUser" class="btn btn-primary">
                <i class="bi bi-person-plus me-1"></i>Add User
            </a>
        </div>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-xl-3 col-md-6">
            <div class="card text-center py-3">
                <div class="fs-2 fw-bold text-primary">@users.Count</div>
                <div class="small text-muted">Total Users</div>
            </div>
        </div>
        <div class="col-xl-3 col-md-6">
            <div class="card text-center py-3">
                <div class="fs-2 fw-bold text-success">@active</div>
                <div class="small text-muted">Active</div>
            </div>
        </div>
        <div class="col-xl-3 col-md-6">
            <div class="card text-center py-3">
                <div class="fs-2 fw-bold text-danger">@suspended</div>
                <div class="small text-muted">Suspended</div>
            </div>
        </div>
        <div class="col-xl-3 col-md-6">
            <div class="card text-center py-3">
                <div class="fs-2 fw-bold text-warning">@pending</div>
                <div class="small text-muted">Pending</div>
            </div>
        </div>
    </div>

    <div class="card mb-4">
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-3">
                    <label class="form-label small text-muted">Search</label>
                    <div class="input-group">
                        <span class="input-group-text"><i class="bi bi-search"></i></span>
                        <input type="text" class="form-control" id="searchUsers" placeholder="Search users...">
                    </div>
                </div>
                <div class="col-md-2">
                    <label class="form-label small text-muted">Role</label>
                    <select class="form-select" id="filterRole">
                        <option value="">All Roles</option>
                        <option>Pharmacy Staff</option>
                        <option>Pharmacy Manager</option>
                        <option>Distributor</option>
                        <option>MOH Admin</option>
                        <option>System Admin</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label small text-muted">Status</label>
                    <select class="form-select" id="filterStatus">
                        <option value="">All Status</option>
                        <option value="Active">Active</option>
                        <option value="Suspended">Suspended</option>
                        <option value="Pending">Pending</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label small text-muted">Governorate</label>
                    <select class="form-select" id="filterGov">
                        <option value="">All Governorates</option>
                        <option>Amman</option>
                        <option>Irbid</option>
                        <option>Zarqa</option>
                        <option>Balqa</option>
                        <option>Madaba</option>
                        <option>Mafraq</option>
                        <option>Karak</option>
                        <option>Aqaba</option>
                    </select>
                </div>
                <div class="col-md-3 d-flex align-items-end">
                    <button class="btn btn-outline-secondary w-100" onclick="resetUserFilters()">
                        <i class="bi bi-arrow-counterclockwise me-1"></i>Reset Filters
                    </button>
                </div>
            </div>
        </div>
    </div>

    <div class="card">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-medtrack mb-0" id="usersTable">
                    <thead>
                        <tr>
                            <th><input type="checkbox" class="form-check-input" id="selectAllUsers"></th>
                            <th>User</th>
                            <th>Role</th>
                            <th>Pharmacy</th>
                            <th>Governorate</th>
                            <th>Status</th>
                            <th>Last Login</th>
                            <th>Joined</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var user in users)
                        {
                            var roleBadgeClass = user.Role switch
                            {
                                "System Admin" => "dark",
                                "MOH Admin" => "primary",
                                "Distributor" => "warning text-dark",
                                "Pharmacy Manager" => "success",
                                _ => "info"
                            };
                            <tr data-role="@user.Role" data-status="@user.Status" data-governorate="@(user.Governorate ?? "")">
                                <td><input type="checkbox" class="form-check-input row-checkbox"></td>
                                <td>
                                    <div class="d-flex align-items-center">
                                        <div class="avatar-circle bg-primary text-white me-2" style="width: 32px; height: 32px; font-size: 0.8rem;">
                                            @user.FullName.Substring(0, 1)
                                        </div>
                                        <div>
                                            <div class="fw-bold">@user.FullName</div>
                                            <small class="text-muted">@user.Email</small>
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    <span class="badge bg-@roleBadgeClass bg-opacity-10 text-@roleBadgeClass" style="@(user.Role == "Distributor" ? "color: #ff7900;" : "")">
                                        @user.Role
                                    </span>
                                </td>
                                <td>@(user.PharmacyName ?? "—")</td>
                                <td>@(user.Governorate ?? "—")</td>
                                <td>
                                    @if (user.Status == "Active")
                                    {
                                        <span class="status-badge status-healthy">Active</span>
                                    }
                                    else if (user.Status == "Suspended")
                                    {
                                        <span class="status-badge status-danger">Suspended</span>
                                    }
                                    else
                                    {
                                        <span class="status-badge status-warning">Pending</span>
                                    }
                                </td>
                                <td>@(user.LastLogin?.ToString("MMM dd, HH:mm") ?? "Never")</td>
                                <td>@user.CreatedAt.ToString("MMM dd, yyyy")</td>
                                <td>
                                    <div class="btn-group btn-group-sm">
                                        <a href="/Admin/EditUser/@user.Id" class="btn btn-outline-secondary" title="Edit">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                        @if (user.Status == "Active")
                                        {
                                            <button type="button" class="btn btn-outline-warning"
                                                    data-mt-swal-message="Suspend this user? They will be unable to log in."
                                                    data-mt-swal-title="Suspend user"
                                                    data-mt-swal-icon="warning"
                                                    data-mt-swal-confirm-text="Suspend"
                                                    data-mt-swal-success="User suspended"
                                                    data-mt-swal-success-type="warning"
                                                    title="Suspend">
                                                <i class="bi bi-pause-circle"></i>
                                            </button>
                                        }
                                        else
                                        {
                                            <button type="button" class="btn btn-outline-success" onclick="activateUser()" title="Activate">
                                                <i class="bi bi-play-circle"></i>
                                            </button>
                                        }
                                        <button type="button" class="btn btn-outline-danger"
                                                data-mt-swal-message="Delete this user permanently? This cannot be undone."
                                                data-mt-swal-title="Delete user"
                                                data-mt-swal-icon="warning"
                                                data-mt-swal-danger="true"
                                                data-mt-swal-confirm-text="Delete"
                                                data-mt-swal-success="User deleted"
                                                title="Delete">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                        @if (!users.Any())
                        {
                            <tr>
                                <td colspan="9" class="text-center py-5 text-muted">
                                    <i class="bi bi-inbox fs-1 d-block mb-2"></i>
                                    No users found.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
        <div class="card-footer bg-transparent">
            <div class="d-flex justify-content-between align-items-center">
                <span class="text-muted small" id="rowCount">Showing @users.Count items</span>
                <div class="btn-group">
                    <button class="btn btn-outline-secondary btn-sm" id="bulkSuspend">
                        <i class="bi bi-pause-circle me-1"></i>Suspend Selected
                    </button>
                    <button class="btn btn-outline-danger btn-sm" id="bulkDeleteUsers">
                        <i class="bi bi-trash me-1"></i>Delete Selected
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function activateUser() {
            showToast('User activated', 'success');
        }

        $('#bulkSuspend').on('click', function () {
            mtConfirm('Suspend all selected users? They will be unable to log in.', {
                title: 'Suspend selected',
                icon: 'warning',
                confirmText: 'Suspend'
            }).then(function (ok) {
                if (ok) showToast('Selected users suspended', 'warning');
            });
        });

        $('#bulkDeleteUsers').on('click', function () {
            mtConfirm('Delete all selected users permanently? This cannot be undone.', {
                title: 'Delete selected',
                icon: 'warning',
                danger: true,
                confirmText: 'Delete'
            }).then(function (ok) {
                if (ok) showToast('Selected users deleted', 'success');
            });
        });

        function filterRows() {
            var search = $('#searchUsers').val().toLowerCase();
            var role = $('#filterRole').val();
            var status = $('#filterStatus').val();
            var governorate = $('#filterGov').val();
            var visible = 0;

            $('#usersTable tbody tr').each(function () {
                var $row = $(this);
                if ($row.find('td[colspan]').length) return;

                var text = $row.text().toLowerCase();
                var rowRole = $row.data('role');
                var rowStatus = $row.data('status');
                var rowGov = $row.data('governorate');

                var show = true;
                if (search && text.indexOf(search) === -1) show = false;
                if (role && rowRole !== role) show = false;
                if (status && rowStatus !== status) show = false;
                if (governorate && rowGov !== governorate) show = false;

                $row.toggle(show);
                if (show) visible++;
            });

            $('#rowCount').text('Showing ' + visible + ' items');
        }

        function resetUserFilters() {
            $('#searchUsers').val('');
            $('#filterRole, #filterStatus, #filterGov').val('');
            $('#usersTable tbody tr').show();
            $('#rowCount').text('Showing @users.Count items');
        }

        $('#searchUsers').on('keyup', filterRows);
        $('#filterRole, #filterStatus, #filterGov').on('change', filterRows);
    </script>
}
