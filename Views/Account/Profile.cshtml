@model MedTrack.Models.ViewModels.ProfileViewModel
@{
    ViewData["Title"] = "My Profile";
    ViewData["PageIcon"] = "bi-person-circle";
    ViewData["Subtitle"] = "Manage your personal information and account details";
}

<div class="fade-in">
    <partial name="_PageHeader" />

    <div class="row justify-content-center">
        <div class="col-lg-6">
            <div class="card">
                <div class="card-body p-4">
                    <div class="text-center mb-4">
                        <div class="mt-account-avatar">
                            <i class="bi bi-person"></i>
                        </div>
                        <h4 class="fw-bold mt-3 mb-1">@Model.FullName</h4>
                        <span class="mt-account-badge">@Model.Role</span>
                    </div>

                    <form asp-action="Profile" method="post">
                        @Html.AntiForgeryToken()
                        <div asp-validation-summary="All" class="alert alert-danger py-2 small"></div>

                        <div class="mb-3">
                            <label asp-for="FullName" class="form-label fw-semibold"></label>
                            <input asp-for="FullName" class="form-control" />
                            <span asp-validation-for="FullName" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Email" class="form-label fw-semibold"></label>
                            <input asp-for="Email" class="form-control" readonly />
                            <div class="form-text">Email cannot be changed here.</div>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Role" class="form-label fw-semibold"></label>
                            <input asp-for="Role" class="form-control" readonly />
                        </div>

                        <div class="d-flex gap-2 flex-wrap">
                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-check-lg me-1"></i> Save Changes
                            </button>
                            <a asp-action="ChangePassword" class="btn btn-outline-secondary">
                                <i class="bi bi-key me-1"></i> Change Password
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
