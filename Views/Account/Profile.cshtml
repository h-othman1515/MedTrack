@model MedTrack.Models.ViewModels.ProfileViewModel
@{
    ViewData["Title"] = "My Profile";
    var initial = Model.FullName?.Substring(0, 1).ToUpper() ?? "U";
}

<div class="fade-in">

    <!-- ── Header ── -->
    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
        <div>
            <h2 class="fw-bold mb-1"><i class="bi bi-person-circle me-2"></i>My Profile</h2>
            <p class="text-muted mb-0">Manage your personal information and account details</p>
        </div>
    </div>

    <div class="row g-4">

        <!-- ── Left: Avatar Card ── -->
        <div class="col-lg-4">
            <div class="card text-center p-4 mb-4">
                <div class="mx-auto mb-3 rounded-circle bg-primary bg-opacity-10 text-primary d-flex align-items-center justify-content-center fw-bold"
                     style="width:90px;height:90px;font-size:2.2rem;">
                    @initial
                </div>
                <h4 class="fw-bold mb-1">@Model.FullName</h4>
                <span class="badge bg-primary bg-opacity-10 text-primary border border-primary border-opacity-25 rounded-pill px-3 py-1 mb-3">
                    @Model.Role
                </span>
                <hr class="my-3">
                <div class="d-flex flex-column gap-2 text-start">
                    <div class="d-flex align-items-center gap-2 small text-muted">
                        <i class="bi bi-envelope"></i>
                        <span>@Model.Email</span>
                    </div>
                    <div class="d-flex align-items-center gap-2 small text-muted">
                        <i class="bi bi-shield-check text-success"></i>
                        <span>Account Active</span>
                    </div>
                    <div class="d-flex align-items-center gap-2 small text-muted">
                        <i class="bi bi-calendar"></i>
                        <span>Member since @DateTime.Now.Year</span>
                    </div>
                </div>
            </div>

            <!-- Quick Actions -->
            <div class="card">
                <div class="card-header bg-transparent">
                    <h6 class="fw-bold mb-0"><i class="bi bi-lightning me-2 text-warning"></i>Quick Actions</h6>
                </div>
                <div class="card-body p-0">
                    <a asp-action="ChangePassword" class="d-flex align-items-center gap-2 px-3 py-2 border-bottom text-decoration-none text-body">
                        <i class="bi bi-key text-muted"></i>
                        <span class="small">Change Password</span>
                        <i class="bi bi-chevron-right ms-auto text-muted small"></i>
                    </a>
                    <a href="/Account/Settings" class="d-flex align-items-center gap-2 px-3 py-2 text-decoration-none text-body">
                        <i class="bi bi-gear text-muted"></i>
                        <span class="small">Account Settings</span>
                        <i class="bi bi-chevron-right ms-auto text-muted small"></i>
                    </a>
                </div>
            </div>
        </div>

        <!-- ── Right: Edit Form ── -->
        <div class="col-lg-8">
            <div class="card">
                <div class="card-header bg-transparent">
                    <h5 class="fw-bold mb-0"><i class="bi bi-pencil-square me-2 text-primary"></i>Edit Profile</h5>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Profile" method="post">
                        @Html.AntiForgeryToken()
                        <div asp-validation-summary="All" class="alert alert-danger py-2 small mb-3"></div>

                        <div class="mb-4">
                            <label asp-for="FullName" class="form-label fw-semibold">Full Name</label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="bi bi-person"></i></span>
                                <input asp-for="FullName" class="form-control" placeholder="Your full name" />
                            </div>
                            <span asp-validation-for="FullName" class="text-danger small"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Email" class="form-label fw-semibold">Email Address</label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="bi bi-envelope"></i></span>
                                <input asp-for="Email" class="form-control" readonly />
                            </div>
                            <div class="form-text">Email address cannot be changed here.</div>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Role" class="form-label fw-semibold">Role</label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="bi bi-shield"></i></span>
                                <input asp-for="Role" class="form-control" readonly />
                            </div>
                            <div class="form-text">Role is assigned by the system administrator.</div>
                        </div>

                        <hr class="my-4">

                        <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
                            <a asp-action="ChangePassword" class="btn btn-outline-secondary">
                                <i class="bi bi-key me-1"></i>Change Password
                            </a>
                            <button type="submit" class="btn btn-primary px-4">
                                <i class="bi bi-check-lg me-1"></i>Save Changes
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>

    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}