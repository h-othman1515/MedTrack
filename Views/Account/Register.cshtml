@model MedTrack.Models.ViewModels.RegisterViewModel
@{
    ViewData["Title"] = "Register";
    ViewData["HomeTheme"] = true;
    ViewData["NavActive"] = "register";
    Layout = "_Layout";
}

<partial name="_PillField" />
<partial name="_HomeNav" />

<main>
    <section class="mt-auth-page mt-auth-page--wide">
        <div class="mt-auth-wrap mt-auth-wrap--wide">
            <div class="mt-auth-header">
                <div class="mt-auth-icon"><i class="bi bi-capsule-pill"></i></div>
                <h1>Join MedTrack Jordan</h1>
                <p>Register your pharmacy or organization</p>
            </div>

            <div class="mt-auth-card">
                <form asp-action="Register" method="post">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                    <div class="mb-4">
                        <label class="form-label fw-bold">Account Type</label>
                        <div class="row g-2">
                            <div class="col-6">
                                <div class="form-check mt-auth-role-card p-3">
                                    <input class="form-check-input" type="radio" name="Role" id="rolePharmacy" value="Pharmacy Staff" checked>
                                    <label class="form-check-label w-100" for="rolePharmacy">
                                        <i class="bi bi-shop me-2" style="color:var(--mt-teal)"></i>
                                        <strong>Pharmacy</strong>
                                        <small class="d-block text-muted">Staff or Manager</small>
                                    </label>
                                </div>
                            </div>
                            <div class="col-6">
                                <div class="form-check mt-auth-role-card p-3">
                                    <input class="form-check-input" type="radio" name="Role" id="roleDistributor" value="Distributor">
                                    <label class="form-check-label w-100" for="roleDistributor">
                                        <i class="bi bi-truck me-2" style="color:var(--mt-amber)"></i>
                                        <strong>Distributor</strong>
                                        <small class="d-block text-muted">Drug supplier</small>
                                    </label>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="FullName" class="form-label"></label>
                            <input asp-for="FullName" class="form-control" placeholder="Full name" />
                            <span asp-validation-for="FullName" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Email" class="form-label"></label>
                            <input asp-for="Email" class="form-control" placeholder="email@pharmacy.jo" />
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="row g-3 mt-1">
                        <div class="col-md-6">
                            <label asp-for="Password" class="form-label"></label>
                            <input asp-for="Password" class="form-control" placeholder="Min 8 characters" />
                            <span asp-validation-for="Password" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="ConfirmPassword" class="form-label"></label>
                            <input asp-for="ConfirmPassword" class="form-control" placeholder="Confirm password" />
                            <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="mt-auth-section-title">Pharmacy Information</div>

                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="PharmacyName" class="form-label"></label>
                            <input asp-for="PharmacyName" class="form-control" placeholder="Pharmacy name" />
                            <span asp-validation-for="PharmacyName" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="LicenseNo" class="form-label"></label>
                            <input asp-for="LicenseNo" class="form-control" placeholder="MOH License Number" />
                            <span asp-validation-for="LicenseNo" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="row g-3 mt-1">
                        <div class="col-md-6">
                            <label asp-for="Governorate" class="form-label"></label>
                            <select asp-for="Governorate" class="form-select">
                                <option value="">Select Governorate</option>
                                <option>Amman</option>
                                <option>Irbid</option>
                                <option>Zarqa</option>
                                <option>Balqa</option>
                                <option>Madaba</option>
                                <option>Ajloun</option>
                                <option>Jerash</option>
                                <option>Mafraq</option>
                                <option>Karak</option>
                                <option>Tafilah</option>
                                <option>Ma'an</option>
                                <option>Aqaba</option>
                            </select>
                            <span asp-validation-for="Governorate" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Phone" class="form-label"></label>
                            <input asp-for="Phone" class="form-control" placeholder="+962 7X XXX XXXX" />
                            <span asp-validation-for="Phone" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="mb-3 mt-3">
                        <label asp-for="Address" class="form-label"></label>
                        <textarea asp-for="Address" class="form-control" rows="2" placeholder="Full address"></textarea>
                        <span asp-validation-for="Address" class="text-danger small"></span>
                    </div>

                    <div class="form-check mb-3">
                        <input class="form-check-input" type="checkbox" id="terms" required>
                        <label class="form-check-label small" for="terms">
                            I agree to the <a href="#">Terms of Service</a> and <a href="#">Privacy Policy</a>. I confirm that the pharmacy information provided is accurate.
                        </label>
                    </div>

                    <button type="submit" class="btn-primary-mt w-100 justify-content-center mb-3">
                        <i class="bi bi-person-plus"></i> Create Account
                    </button>

                    <div class="text-center">
                        <p class="text-muted small mb-0">
                            Already have an account? <a href="/Account/Login" class="text-decoration-none">Sign In</a>
                        </p>
                    </div>
                </form>
            </div>

            <div class="mt-auth-footer">MedTrack Jordan — Orange Internship 2025</div>
        </div>
    </section>
</main>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
