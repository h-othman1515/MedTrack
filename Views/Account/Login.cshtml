@model MedTrack.Models.ViewModels.LoginViewModel
@{
    ViewData["Title"] = "Login";
    ViewData["HomeTheme"] = true;
    ViewData["NavActive"] = "login";
    Layout = "_Layout";
}

<partial name="_PillField" />
<partial name="_HomeNav" />

<main>
    <section class="mt-auth-page">
        <div class="mt-auth-wrap">
            <div class="mt-auth-header">
                <div class="mt-auth-icon"><i class="bi bi-capsule-pill"></i></div>
                <h1>Welcome Back</h1>
                <p>Sign in to your MedTrack account</p>
            </div>

            <div class="mt-auth-card">
                <form asp-controller="Account" asp-action="Login" method="post">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                    <div class="mb-3">
                        <label asp-for="Email" class="form-label"></label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-envelope"></i></span>
                            <input asp-for="Email" class="form-control" placeholder="name@pharmacy.jo" />
                        </div>
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Password" class="form-label"></label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-lock"></i></span>
                            <input asp-for="Password" type="password" class="form-control" placeholder="Enter your password" />
                        </div>
                        <span asp-validation-for="Password" class="text-danger small"></span>
                    </div>

                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <div class="form-check">
                            <input asp-for="RememberMe" class="form-check-input" />
                            <label asp-for="RememberMe" class="form-check-label small"></label>
                        </div>
                        <a href="/Account/ForgotPassword" class="small text-decoration-none">Forgot password?</a>
                    </div>

                    <button type="submit" class="btn-primary-mt w-100 justify-content-center mb-3">
                        <i class="bi bi-box-arrow-in-right"></i> Sign In
                    </button>

                    <div class="text-center">
                        <p class="text-muted small mb-0">
                            Don't have an account? <a href="/Account/Register" class="text-decoration-none">Register</a>
                        </p>
                    </div>
                </form>
            </div>

            <div class="mt-auth-footer">MedTrack Jordan — Orange Internship 2025</div>
        </div>
    </section>
</main>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
