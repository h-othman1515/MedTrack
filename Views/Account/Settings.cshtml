@{
    ViewData["Title"] = "Settings";
    var userName = User.Identity?.Name ?? "User";
}

<div class="fade-in">

    <!-- ── Header ── -->
    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
        <div>
            <h2 class="fw-bold mb-1"><i class="bi bi-gear me-2"></i>Settings</h2>
            <p class="text-muted mb-0">Manage your account preferences and notifications</p>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-lg-8">

            <!-- ── Account ── -->
            <div class="card mb-4">
                <div class="card-header bg-transparent">
                    <h5 class="fw-bold mb-0"><i class="bi bi-person me-2 text-primary"></i>Account</h5>
                </div>
                <div class="card-body">
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Display Name</label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-person"></i></span>
                            <input class="form-control" value="@userName" />
                        </div>
                    </div>
                    <div class="mb-4">
                        <label class="form-label fw-semibold">Language</label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-translate"></i></span>
                            <select class="form-select">
                                <option>English</option>
                                <option>العربية</option>
                            </select>
                        </div>
                    </div>
                    <a href="/Account/ChangePassword" class="btn btn-outline-secondary">
                        <i class="bi bi-key me-1"></i>Change Password
                    </a>
                </div>
            </div>

            <!-- ── Notifications ── -->
            <div class="card mb-4">
                <div class="card-header bg-transparent">
                    <h5 class="fw-bold mb-0"><i class="bi bi-bell me-2 text-warning"></i>Notifications</h5>
                </div>
                <div class="card-body p-0">
                    <div class="d-flex align-items-center justify-content-between px-4 py-3 border-bottom">
                        <div>
                            <div class="fw-semibold small"><i class="bi bi-envelope me-2 text-primary"></i>Email Notifications</div>
                            <div class="text-muted small">Receive updates and alerts via email</div>
                        </div>
                        <div class="form-check form-switch mb-0">
                            <input class="form-check-input" type="checkbox" id="emailNotif" checked />
                        </div>
                    </div>
                    <div class="d-flex align-items-center justify-content-between px-4 py-3 border-bottom">
                        <div>
                            <div class="fw-semibold small"><i class="bi bi-calendar-x me-2 text-danger"></i>Expiry Alerts</div>
                            <div class="text-muted small">Get notified when medications are near expiry</div>
                        </div>
                        <div class="form-check form-switch mb-0">
                            <input class="form-check-input" type="checkbox" id="expiryNotif" checked />
                        </div>
                    </div>
                    <div class="d-flex align-items-center justify-content-between px-4 py-3">
                        <div>
                            <div class="fw-semibold small"><i class="bi bi-exclamation-triangle me-2 text-warning"></i>Shortage Alerts</div>
                            <div class="text-muted small">Get notified about stock shortages</div>
                        </div>
                        <div class="form-check form-switch mb-0">
                            <input class="form-check-input" type="checkbox" id="shortageNotif" checked />
                        </div>
                    </div>
                </div>
            </div>

            <!-- ── Appearance ── -->
            <div class="card">
                <div class="card-header bg-transparent">
                    <h5 class="fw-bold mb-0"><i class="bi bi-palette me-2 text-info"></i>Appearance</h5>
                </div>
                <div class="card-body p-0">
                    <div class="d-flex align-items-center justify-content-between px-4 py-3">
                        <div>
                            <div class="fw-semibold small"><i class="bi bi-moon me-2"></i>Dark Mode</div>
                            <div class="text-muted small">Switch between light and dark theme</div>
                        </div>
                        <button class="btn btn-sm btn-outline-secondary" id="themeToggleBtn" onclick="document.getElementById('themeToggle')?.click()">
                            <i class="bi bi-moon-stars me-1"></i>Toggle Theme
                        </button>
                    </div>
                </div>
            </div>

        </div>

        <!-- ── Sidebar ── -->
        <div class="col-lg-4">

            <!-- Profile Summary -->
            <div class="card mb-4 text-center p-4">
                @{
                    var initial = userName.Substring(0, 1).ToUpper();
                }
                <div class="mx-auto mb-3 rounded-circle bg-primary bg-opacity-10 text-primary d-flex align-items-center justify-content-center fw-bold"
                     style="width:70px;height:70px;font-size:1.8rem;">
                    @initial
                </div>
                <h6 class="fw-bold mb-1">@userName</h6>
                <p class="text-muted small mb-3">@User.Claims.FirstOrDefault(c => c.Type.Contains("role"))?.Value</p>
                <a href="/Account/Profile" class="btn btn-outline-primary btn-sm w-100">
                    <i class="bi bi-person-circle me-1"></i>View Profile
                </a>
            </div>

            <!-- Danger Zone -->
            <div class="card border-danger">
                <div class="card-header bg-danger bg-opacity-10">
                    <h6 class="fw-bold mb-0 text-danger"><i class="bi bi-exclamation-triangle me-2"></i>Danger Zone</h6>
                </div>
                <div class="card-body">
                    <p class="small text-muted mb-3">These actions are permanent and cannot be undone.</p>
                    <div class="d-grid gap-2">
                        <button class="btn btn-outline-danger btn-sm"
                                data-mt-swal-message="Are you sure you want to log out of all devices?"
                                data-mt-swal-title="Sign out everywhere"
                                data-mt-swal-icon="warning"
                                data-mt-swal-confirm-text="Sign Out All">
                            <i class="bi bi-box-arrow-right me-1"></i>Sign Out All Devices
                        </button>
                        <button class="btn btn-outline-danger btn-sm"
                                data-mt-swal-message="This will permanently delete your account and all data."
                                data-mt-swal-title="Delete account"
                                data-mt-swal-icon="warning"
                                data-mt-swal-danger="true"
                                data-mt-swal-confirm-text="Delete">
                            <i class="bi bi-trash me-1"></i>Delete Account
                        </button>
                    </div>
                </div>
            </div>

        </div>
    </div>
</div>