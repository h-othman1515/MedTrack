@model MedTrack.Models.ViewModels.SurplusCreateViewModel
@{
    ViewData["Title"] = "List Surplus";
    Layout = "_Layout";
}

<div class="fade-in">
    <div class="mb-4">
        <a href="/Surplus" class="text-decoration-none text-muted">
            <i class="bi bi-arrow-left me-1"></i>Back to Marketplace
        </a>
    </div>

    <div class="row justify-content-center">
        <div class="col-lg-6">
            <div class="card">
                <div class="card-header bg-white">
                    <h4 class="fw-bold mb-0"><i class="bi bi-arrow-up-circle me-2 text-success"></i>List Surplus Stock</h4>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Create" method="post">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                        <div class="mb-3">
                            <label asp-for="DrugId" class="form-label"></label>
                            <select asp-for="DrugId" asp-items="ViewBag.DrugOptions" class="form-select">
                                <option value="">Select from your inventory...</option>
                            </select>
                            <span asp-validation-for="DrugId" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Quantity" class="form-label"></label>
                            <input asp-for="Quantity" class="form-control" type="number" min="1" placeholder="How many units to list?" />
                            <span asp-validation-for="Quantity" class="text-danger small"></span>
                            <div class="form-text">You can list partial quantities. Remaining stock stays in your inventory.</div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="ExpiryDate" class="form-label"></label>
                            <input asp-for="ExpiryDate" class="form-control" type="date" />
                            <span asp-validation-for="ExpiryDate" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Price" class="form-label"></label>
                            <div class="input-group">
                                <span class="input-group-text">JOD</span>
                                <input asp-for="Price" class="form-control" type="number" step="0.01" min="0" placeholder="Leave empty for free sharing" />
                            </div>
                            <span asp-validation-for="Price" class="text-danger small"></span>
                            <div class="form-text">Leave empty to offer for free. Recommended for near-expiry items.</div>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Condition" class="form-label"></label>
                            <textarea asp-for="Condition" class="form-control" rows="3" placeholder="Describe storage conditions, packaging status, etc."></textarea>
                            <span asp-validation-for="Condition" class="text-danger small"></span>
                        </div>

                        <div class="alert alert-info">
                            <i class="bi bi-info-circle me-2"></i>
                            <strong>Note:</strong> Once listed, other pharmacies can request transfers. You'll be notified via SMS and email.
                        </div>

                        <div class="d-flex justify-content-between">
                            <a href="/Surplus" class="btn btn-outline-secondary">Cancel</a>
                            <button type="submit" class="btn btn-success">
                                <i class="bi bi-check-lg me-1"></i>List Surplus
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
