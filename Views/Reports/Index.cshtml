@model MedTrack.Models.ViewModels.WasteReportViewModel
@{
    ViewData["Title"] = "Waste Reports";
    var items = Model.Items;
}

<div class="fade-in">
    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
        <div>
            <h2 class="fw-bold mb-1"><i class="bi bi-graph-up me-2"></i>Waste Reports</h2>
            <p class="text-muted mb-0">
                Period: @Model.PeriodStart.ToString("yyyy-MM-dd") &ndash; @Model.PeriodEnd.ToString("yyyy-MM-dd")
            </p>
        </div>
        <button class="btn btn-outline-secondary" onclick="window.print()">
            <i class="bi bi-printer me-1"></i>Print / Export
        </button>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-xl-3 col-md-6">
            <div class="card text-center py-3">
                <div class="fs-5 fw-bold text-danger">@Model.TotalWasteValue.ToString("N2") JOD</div>
                <div class="small text-muted">Total Waste Value</div>
            </div>
        </div>
        <div class="col-xl-3 col-md-6">
            <div class="card text-center py-3">
                <div class="fs-2 fw-bold text-warning">@Model.TotalItemsWasted</div>
                <div class="small text-muted">Items Wasted</div>
            </div>
        </div>
        <div class="col-xl-3 col-md-6">
            <div class="card text-center py-3">
                <div class="fs-2 fw-bold text-primary">@items.Count</div>
                <div class="small text-muted">Waste Records</div>
            </div>
        </div>
        <div class="col-xl-3 col-md-6">
            <div class="card text-center py-3">
                <div class="fs-2 fw-bold text-success">@items.Select(i => i.DrugName).Distinct().Count()</div>
                <div class="small text-muted">Drugs Affected</div>
            </div>
        </div>
    </div>

    <div class="card mb-4">
        <div class="card-body">
            <form method="get" asp-action="Index" class="row g-3 align-items-end">
                <div class="col-md-3">
                    <label class="form-label small text-muted" for="periodFrom">From</label>
                    <input type="date" class="form-control" id="periodFrom" name="from"
                           value="@Model.PeriodStart.ToString("yyyy-MM-dd")" />
                </div>
                <div class="col-md-3">
                    <label class="form-label small text-muted" for="periodTo">To</label>
                    <input type="date" class="form-control" id="periodTo" name="to"
                           value="@Model.PeriodEnd.ToString("yyyy-MM-dd")" />
                </div>
                <div class="col-md-3">
                    <button type="submit" class="btn btn-primary w-100">
                        <i class="bi bi-arrow-repeat me-1"></i>Update Period
                    </button>
                </div>
                <div class="col-md-3">
                    <label class="form-label small text-muted">Search</label>
                    <div class="input-group">
                        <span class="input-group-text"><i class="bi bi-search"></i></span>
                        <input type="text" class="form-control" id="searchInput" placeholder="Drug, batch...">
                    </div>
                </div>
            </form>
            <div class="mt-3">
                <button class="btn btn-outline-secondary btn-sm" onclick="resetFilters()">
                    <i class="bi bi-arrow-counterclockwise me-1"></i>Reset Filters
                </button>
            </div>
        </div>
    </div>

    <div class="card">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-medtrack mb-0" id="wasteTable">
                    <thead>
                        <tr>
                            <th>Drug</th>
                            <th>Batch</th>
                            <th>Qty</th>
                            <th>Unit Price</th>
                            <th>Total Value</th>
                            <th>Expiry</th>
                            <th>Disposal</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in items)
                        {
                            <tr>
                                <td class="fw-semibold">@item.DrugName</td>
                                <td><code>@item.BatchNo</code></td>
                                <td>@item.Quantity</td>
                                <td>@item.UnitPrice.ToString("N2")</td>
                                <td>@item.TotalValue.ToString("N2")</td>
                                <td>@item.ExpiryDate.ToString("yyyy-MM-dd")</td>
                                <td>@item.DisposalMethod</td>
                            </tr>
                        }
                        @if (!items.Any())
                        {
                            <tr>
                                <td colspan="7" class="text-center py-5 text-muted">
                                    <i class="bi bi-inbox fs-1 d-block mb-2"></i>
                                    No waste recorded for this period.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
        <div class="card-footer bg-transparent d-flex justify-content-between align-items-center">
            <span class="text-muted small" id="rowCount">Showing @items.Count items</span>
            @if (items.Any())
            {
                <button class="btn btn-outline-secondary btn-sm" onclick="exportTableToCSV('wasteTable', 'waste-report.csv')">
                    <i class="bi bi-download me-1"></i>Export CSV
                </button>
            }
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function filterRows() {
            var search = $('#searchInput').val().toLowerCase();
            var visible = 0;

            $('#wasteTable tbody tr').each(function () {
                var $row = $(this);
                if ($row.find('td[colspan]').length) return;

                var text = $row.text().toLowerCase();
                var show = !search || text.indexOf(search) !== -1;

                $row.toggle(show);
                if (show) visible++;
            });

            $('#rowCount').text('Showing ' + visible + ' items');
        }

        function resetFilters() {
            $('#searchInput').val('');
            $('#wasteTable tbody tr').show();
            $('#rowCount').text('Showing @items.Count items');
        }

        $('#searchInput').on('keyup', filterRows);
    </script>
}
