<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — MedTrack Jordan</title>

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    @* Page-specific styles injected here *@
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>

    <nav class="navbar navbar-expand-lg navbar-dark shadow-sm" style="background:#1F4E79;">
        <div class="container">

            <a class="navbar-brand fw-bold d-flex align-items-center gap-2" asp-controller="Home" asp-action="Index">
                <i class="bi bi-capsule fs-5"></i>MedTrack Jordan
            </a>

            <button class="navbar-toggler" type="button"
                    data-bs-toggle="collapse" data-bs-target="#navbarMain"
                    aria-controls="navbarMain" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navbarMain">
                <ul class="navbar-nav me-auto mb-2 mb-lg-0">

                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Home" asp-action="Index">
                            <i class="bi bi-house me-1"></i>Home
                        </a>
                    </li>

                    @if (User.Identity!.IsAuthenticated)
                    {
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="MedicationBatch" asp-action="Index">
                                <i class="bi bi-box-seam me-1"></i>Inventory
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="SurplusPost" asp-action="Index">
                                <i class="bi bi-arrow-left-right me-1"></i>Surplus Board
                            </a>
                        </li>

                        @if (User.IsInRole("Admin") || User.IsInRole("PharmacyManager"))
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    <i class="bi bi-gear me-1"></i>Manage
                                </a>
                                <ul class="dropdown-menu border-0 shadow-sm">
                                    <li>
                                        <a class="dropdown-item" asp-controller="Pharmacy" asp-action="Index">
                                            <i class="bi bi-building me-2 text-primary"></i>Pharmacies
                                        </a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item" asp-controller="Drug" asp-action="Index">
                                            <i class="bi bi-capsule me-2 text-primary"></i>Drugs
                                        </a>
                                    </li>
                                    @if (User.IsInRole("Admin"))
                                    {
                                        <li><hr class="dropdown-divider" /></li>
                                        <li>
                                            <a class="dropdown-item" asp-controller="Admin" asp-action="Users">
                                                <i class="bi bi-people me-2 text-primary"></i>Users
                                            </a>
                                        </li>
                                    }
                                </ul>
                            </li>
                        }

                        @if (User.IsInRole("Admin") || User.IsInRole("MOHAdmin"))
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Admin" asp-action="Dashboard">
                                    <i class="bi bi-bar-chart-line me-1"></i>Dashboard
                                </a>
                            </li>
                        }

                        @if (User.IsInRole("Distributor"))
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="RestockRequest" asp-action="Index">
                                    <i class="bi bi-truck-front me-1"></i>Restock Requests
                                </a>
                            </li>
                        }
                    }

                </ul>

                <ul class="navbar-nav ms-auto mb-2 mb-lg-0">
                    @if (User.Identity!.IsAuthenticated)
                    {
                        @* Notification Bell *@
                        <li class="nav-item me-1">
                            <a class="nav-link position-relative" asp-controller="Notification" asp-action="Index"
                               title="Notifications">
                                <i class="bi bi-bell fs-5"></i>
                                @* Badge count injected by ViewBag from controller *@
                                @if (ViewBag.UnreadCount != null && ViewBag.UnreadCount > 0)
                                {
                                    <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger"
                                          style="font-size:0.65rem;">
                                        @ViewBag.UnreadCount
                                    </span>
                                }
                            </a>
                        </li>

                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle d-flex align-items-center gap-2"
                               href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                <span class="avatar-circle">@(User.Identity.Name?.Substring(0, 1).ToUpper())</span>
                                <span class="d-none d-md-inline" style="font-size:0.875rem;">@User.Identity.Name</span>
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end border-0 shadow-sm">
                                <li class="px-3 py-2 border-bottom">
                                    <small class="text-muted d-block">Signed in as</small>
                                    <strong style="font-size:0.875rem;">@User.Identity.Name</strong>
                                </li>
                                <li>
                                    <a class="dropdown-item" asp-controller="Account" asp-action="Profile">
                                        <i class="bi bi-person me-2"></i>My Profile
                                    </a>
                                </li>
                                <li>
                                    <a class="dropdown-item" asp-controller="Account" asp-action="ChangePassword">
                                        <i class="bi bi-key me-2"></i>Change Password
                                    </a>
                                </li>
                                <li><hr class="dropdown-divider" /></li>
                                <li>
                                    <form asp-controller="Account" asp-action="Logout" method="post">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="dropdown-item text-danger">
                                            <i class="bi bi-box-arrow-right me-2"></i>Logout
                                        </button>
                                    </form>
                                </li>
                            </ul>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Account" asp-action="Login">
                                <i class="bi bi-box-arrow-in-right me-1"></i>Login
                            </a>
                        </li>
                        <li class="nav-item ms-2">
                            <a class="btn btn-light btn-sm px-3 fw-semibold" asp-controller="Account" asp-action="Register">
                                Register
                            </a>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </nav>

    @* ── Alert toasts ────────────────────────────────────────────────────────────── *@
    @if (TempData["Success"] != null)
    {
        <div class="toast-container position-fixed top-0 end-0 p-3" style="z-index:9999">
            <div class="toast show align-items-center text-bg-success border-0 shadow" role="alert">
                <div class="d-flex">
                    <div class="toast-body">
                        <i class="bi bi-check-circle me-2"></i>@TempData["Success"]
                    </div>
                    <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
                </div>
            </div>
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="toast-container position-fixed top-0 end-0 p-3" style="z-index:9999">
            <div class="toast show align-items-center text-bg-danger border-0 shadow" role="alert">
                <div class="d-flex">
                    <div class="toast-body">
                        <i class="bi bi-exclamation-circle me-2"></i>@TempData["Error"]
                    </div>
                    <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
                </div>
            </div>
        </div>
    }

    @* ── Page body ───────────────────────────────────────────────────────────────── *@
    <main>
        @RenderBody()
    </main>

    <footer class="border-top py-3 mt-5 bg-light">
        <div class="container text-center">
            <small class="text-muted">
                MedTrack Jordan &copy; @DateTime.Now.Year &nbsp;|&nbsp;
                Orange Internship 2025 &nbsp;|&nbsp;
                Built with ASP.NET Core 8
            </small>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    <script>
        // Auto-dismiss toasts after 4 s
        document.querySelectorAll('.toast').forEach(t => {
            setTimeout(() => {
                const toast = bootstrap.Toast.getOrCreateInstance(t);
                toast.hide();
            }, 4000);
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
