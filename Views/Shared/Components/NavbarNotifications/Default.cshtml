@model MedTrack.Models.ViewModels.NavbarNotificationsViewModel

<div style="position:relative">
    <button class="topbar-bell" id="notifBtn" aria-label="Notifications">
        <i class="bi bi-bell"></i>
        @if (Model.UnreadCount > 0)
        {
            <span class="topbar-bell__badge" id="notifCount">@Model.UnreadCount</span>
        }
    </button>
    <div class="notif-dropdown" id="notifDropdown">
        <div class="notif-dropdown__head">
            Notifications <a href="@Model.ViewAllUrl">View all</a>
        </div>
        @if (Model.Items.Any())
        {
            foreach (var item in Model.Items)
            {
                <div class="notif-item">
                    <span class="notif-dot" style="background:@item.DotColor"></span>
                    <div>
                        <div class="notif-title">@item.Title</div>
                        <div class="notif-body">@item.Body</div>
                        <div class="notif-time">@FormatRelativeTime(item.SentAt)</div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="notif-item">
                <div class="text-muted small py-2">No new notifications.</div>
            </div>
        }
    </div>
</div>

@functions {
    private static string FormatRelativeTime(DateTime sentAt)
    {
        var local = sentAt.Kind == DateTimeKind.Utc ? sentAt.ToLocalTime() : sentAt;
        var span = DateTime.Now - local;
        if (span.TotalMinutes < 1) return "Just now";
        if (span.TotalMinutes < 60) return $"{(int)span.TotalMinutes} minute(s) ago";
        if (span.TotalHours < 24) return $"{(int)span.TotalHours} hour(s) ago";
        if (span.TotalDays < 7) return $"{(int)span.TotalDays} day(s) ago";
        return local.ToString("yyyy-MM-dd");
    }
}
