@model IEnumerable<MedTrackJordan.Models.Drug>
@{ ViewData["Title"] = "Drug Catalog"; }

<div class="d-flex justify-content-between align-items-center mb-4">
    <h3 class="fw-bold"><i class="bi bi-capsule me-2"></i>Drug Catalog</h3>
    @if (User.IsInRole("Admin") || User.IsInRole("MOHAdmin"))
    {
        <a asp-action="Create" class="btn btn-primary">
            <i class="bi bi-plus-lg me-1"></i>Add Drug
        </a>
    }
</div>

<div class="row g-3">
    @foreach (var item in Model)
    {
        <div class="col-md-6 col-lg-4">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start">
                        <h5 class="fw-bold mb-1">@item.GenericName</h5>
                        <span class="badge bg-info text-dark">@item.Category</span>
                    </div>
                    <div class="small text-muted mb-3">Min Stock: @item.MinStockLevel @item.Unit</div>

                    <div class="d-flex gap-2">
                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">
                            <i class="bi bi-eye me-1"></i>Details
                        </a>
                        @if (User.IsInRole("Admin") || User.IsInRole("MOHAdmin"))
                        {
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-warning">
                                <i class="bi bi-pencil me-1"></i>Edit
                            </a>
                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger">
                                <i class="bi bi-trash me-1"></i>Delete
                            </a>
                        }
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@if (!Model.Any())
{
    <div class="text-center py-5 text-muted">
        <i class="bi bi-capsule fs-1"></i>
        <p class="mt-2">No drugs in catalog.</p>
    </div>
}