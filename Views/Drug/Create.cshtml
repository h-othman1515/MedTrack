@model MedTrack.Models.Drug
@{
    ViewData["Title"] = "Add Drug";
    ViewData["PageIcon"] = "bi-capsule-pill";
    ViewData["Subtitle"] = "Add a new medication to the catalog";
    ViewData["BackUrl"] = Url.Action("Index");
}

<div class="fade-in">
    <partial name="_PageHeader" />

    <div class="row justify-content-center">
        <div class="col-lg-6">
            <div class="card">
                <div class="card-body p-4">
                    <form asp-action="Create">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small"></div>

                        <div class="mb-3">
                            <label asp-for="GenericName" class="form-label fw-semibold"></label>
                            <input asp-for="GenericName" class="form-control" />
                            <span asp-validation-for="GenericName" class="text-danger small"></span>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="Category" class="form-label fw-semibold"></label>
                                <input asp-for="Category" class="form-control" placeholder="e.g. Antibiotic" />
                                <span asp-validation-for="Category" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="DefaultUnit" class="form-label fw-semibold"></label>
                                <input asp-for="DefaultUnit" class="form-control" placeholder="e.g. Tablet" />
                                <span asp-validation-for="DefaultUnit" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="mb-4">
                            <label asp-for="DefaultMinStockLevel" class="form-label fw-semibold"></label>
                            <input asp-for="DefaultMinStockLevel" class="form-control" type="number" min="0" />
                            <span asp-validation-for="DefaultMinStockLevel" class="text-danger small"></span>
                        </div>

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-check-lg me-1"></i>Add
                            </button>
                            <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
