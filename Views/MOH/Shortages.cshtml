@model MedTrack.Models.ViewModels.MOHDashboardViewModel
@{
    ViewData["Title"] = "Shortage Map";
    Layout = "_Layout";
    var hotspots = Model.ShortageHotspots;
    var critical = hotspots.Count(h => h.Severity == "Critical");
    var high = hotspots.Count(h => h.Severity == "High");
    var totalShortages = hotspots.Sum(h => h.ActiveShortages);
}

<div class="fade-in">
    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
        <div>
            <h2 class="fw-bold mb-1"><i class="bi bi-exclamation-triangle me-2"></i>National Shortage Map</h2>
            <p class="text-muted mb-0">Geographic visualization of medication shortages across Jordan's governorates</p>
        </div>
        <div class="d-flex gap-2">
            <a href="/MOH/Dashboard" class="btn btn-outline-primary">
                <i class="bi bi-speedometer2 me-1"></i>Dashboard
            </a>
            <a href="/MOH/Reports" class="btn btn-primary">
                <i class="bi bi-download me-1"></i>Export
            </a>
        </div>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-xl-3 col-md-6">
            <div class="card text-center py-3">
                <div class="fs-2 fw-bold text-primary">@hotspots.Count</div>
                <div class="small text-muted">Governorates</div>
            </div>
        </div>
        <div class="col-xl-3 col-md-6">
            <div class="card text-center py-3">
                <div class="fs-2 fw-bold text-danger">@totalShortages</div>
                <div class="small text-muted">Active Shortages</div>
            </div>
        </div>
        <div class="col-xl-3 col-md-6">
            <div class="card text-center py-3">
                <div class="fs-2 fw-bold text-warning">@critical</div>
                <div class="small text-muted">Critical Regions</div>
            </div>
        </div>
        <div class="col-xl-3 col-md-6">
            <div class="card text-center py-3">
                <div class="fs-2 fw-bold text-success">@Model.ResolvedThisMonth</div>
                <div class="small text-muted">Resolved This Month</div>
            </div>
        </div>
    </div>

    <div class="card mb-3">
        <div class="card-body py-2">
            <div class="d-flex align-items-center gap-4 flex-wrap">
                <span class="small fw-bold text-muted">Severity:</span>
                <div class="d-flex align-items-center gap-2">
                    <span style="width: 16px; height: 16px; background: #dc3545; border-radius: 50%; display: inline-block;"></span>
                    <small>Critical (&gt;10 shortages)</small>
                </div>
                <div class="d-flex align-items-center gap-2">
                    <span style="width: 16px; height: 16px; background: #ffc107; border-radius: 50%; display: inline-block;"></span>
                    <small>High (5-10 shortages)</small>
                </div>
                <div class="d-flex align-items-center gap-2">
                    <span style="width: 16px; height: 16px; background: #0dcaf0; border-radius: 50%; display: inline-block;"></span>
                    <small>Medium (3-4 shortages)</small>
                </div>
                <div class="d-flex align-items-center gap-2">
                    <span style="width: 16px; height: 16px; background: #198754; border-radius: 50%; display: inline-block;"></span>
                    <small>Low (1-2 shortages)</small>
                </div>
            </div>
        </div>
    </div>

    <div class="card mb-4">
        <div class="card-body p-0">
            <div id="shortageMap"></div>
        </div>
    </div>

    <div class="card mb-4">
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-4">
                    <label class="form-label small text-muted">Search</label>
                    <div class="input-group">
                        <span class="input-group-text"><i class="bi bi-search"></i></span>
                        <input type="text" class="form-control" id="searchInput" placeholder="Governorate, drug...">
                    </div>
                </div>
                <div class="col-md-3">
                    <label class="form-label small text-muted">Severity</label>
                    <select class="form-select" id="filterSeverity">
                        <option value="">All Severity</option>
                        <option value="Critical">Critical</option>
                        <option value="High">High</option>
                        <option value="Medium">Medium</option>
                        <option value="Low">Low</option>
                    </select>
                </div>
                <div class="col-md-3 d-flex align-items-end">
                    <button class="btn btn-outline-secondary w-100" onclick="resetFilters()">
                        <i class="bi bi-arrow-counterclockwise me-1"></i>Reset Filters
                    </button>
                </div>
            </div>
        </div>
    </div>

    <div class="card">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-medtrack mb-0" id="shortagesTable">
                    <thead>
                        <tr>
                            <th>Governorate</th>
                            <th>Pharmacies</th>
                            <th>Active Shortages</th>
                            <th>Severity</th>
                            <th>Top Short Drug</th>
                            <th>Last Updated</th>
                            <th>Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var hotspot in hotspots)
                        {
                            var severityBadge = hotspot.Severity switch
                            {
                                "Critical" => "danger",
                                "High" => "warning text-dark",
                                _ => "info"
                            };
                            <tr data-severity="@hotspot.Severity">
                                <td class="fw-bold">@hotspot.Governorate</td>
                                <td>@hotspot.PharmaciesAffected</td>
                                <td><span class="fw-bold text-@(hotspot.Severity == "Critical" ? "danger" : hotspot.Severity == "High" ? "warning" : "info")">@hotspot.ActiveShortages</span></td>
                                <td><span class="badge bg-@severityBadge">@hotspot.Severity</span></td>
                                <td>@hotspot.TopShortDrug</td>
                                <td>@DateTime.Now.ToString("MMM dd, HH:mm")</td>
                                <td>
                                    <a href="/MOH/Details?governorate=@hotspot.Governorate" class="btn btn-sm btn-outline-primary" title="Details">
                                        <i class="bi bi-eye"></i> Details
                                    </a>
                                </td>
                            </tr>
                        }
                        @if (!hotspots.Any())
                        {
                            <tr>
                                <td colspan="7" class="text-center py-5 text-muted">
                                    <i class="bi bi-inbox fs-1 d-block mb-2"></i>
                                    No shortage data available.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
        <div class="card-footer bg-transparent">
            <span class="text-muted small" id="rowCount">Showing @hotspots.Count items</span>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        window.mtShortageMapData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
            hotspots.Select(h => new {
                name = h.Governorate,
                lat = h.Latitude,
                lng = h.Longitude,
                shortages = h.ActiveShortages,
                severity = h.Severity.ToLowerInvariant(),
                pharmacies = h.PharmaciesAffected
            })
        ));

        function filterRows() {
            var search = $('#searchInput').val().toLowerCase();
            var severity = $('#filterSeverity').val();
            var visible = 0;

            $('#shortagesTable tbody tr').each(function () {
                var $row = $(this);
                if ($row.find('td[colspan]').length) return;

                var text = $row.text().toLowerCase();
                var rowSeverity = $row.data('severity');

                var show = true;
                if (search && text.indexOf(search) === -1) show = false;
                if (severity && rowSeverity !== severity) show = false;

                $row.toggle(show);
                if (show) visible++;
            });

            $('#rowCount').text('Showing ' + visible + ' items');
        }

        function resetFilters() {
            $('#searchInput').val('');
            $('#filterSeverity').val('');
            $('#shortagesTable tbody tr').show();
            $('#rowCount').text('Showing @hotspots.Count items');
        }

        $('#searchInput').on('keyup', filterRows);
        $('#filterSeverity').on('change', filterRows);

        $(document).ready(function () {
            initShortageMap();
        });
    </script>
}
