@model MedTrack.Models.MedicationBatch
@{
    ViewData["Title"] = "Delete Batch";
    ViewData["PageIcon"] = "bi-exclamation-triangle";
    ViewData["Subtitle"] = "Remove inventory batch";
    ViewData["BackUrl"] = Url.Action("Index");
}

<div class="fade-in">
    <partial name="_PageHeader" />

    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card border-danger">
                <div class="card-body p-4 text-center">
                    <i class="bi bi-exclamation-triangle text-danger fs-1"></i>
                    <h4 class="fw-bold mt-3">Delete Batch?</h4>
                    <p class="text-muted">
                        <strong>@Model.Drug.GenericName</strong> — @Model.Quantity units from @Model.Pharmacy.Name
                    </p>

                    <dl class="row text-start mt-4">
                        <dt class="col-sm-4">Batch No</dt>
                        <dd class="col-sm-8"><code>@Model.BatchNo</code></dd>
                        <dt class="col-sm-4">Expiry</dt>
                        <dd class="col-sm-8">@Model.ExpiryDate.ToString("yyyy-MM-dd")</dd>
                    </dl>

                    <form asp-action="Delete" class="mt-4"
                          data-mt-swal-confirm="Delete this batch of @Model.Drug.GenericName?"
                          data-mt-swal-title="Confirm deletion"
                          data-mt-swal-icon="warning"
                          data-mt-swal-danger="true"
                          data-mt-swal-confirm-text="Delete">
                        <input type="hidden" asp-for="Id" />
                        <button type="submit" class="btn btn-danger fw-semibold">
                            <i class="bi bi-trash me-1"></i>Confirm Delete
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary ms-2">Cancel</a>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
