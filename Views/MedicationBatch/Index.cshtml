@model IEnumerable<MedTrack.Models.MedicationBatch>
@{
    ViewData["Title"] = "Inventory";
    var list = Model.ToList();
    var now = DateTime.UtcNow;
    var good = list.Count(b => (b.ExpiryDate - now).Days > 60);
    var warning = list.Count(b => { var d = (b.ExpiryDate - now).Days; return d > 30 && d <= 60; });
    var critical = list.Count(b => { var d = (b.ExpiryDate - now).Days; return d >= 0 && d <= 30; });
    var expired = list.Count(b => (b.ExpiryDate - now).Days < 0);
}

<div class="fade-in">
    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
        <div>
            <h2 class="fw-bold mb-1"><i class="bi bi-box-seam me-2"></i>Inventory Dashboard</h2>
            <p class="text-muted mb-0">Track batches, expiry status, and stock levels</p>
        </div>
        <a asp-action="Create" class="btn btn-primary">
            <i class="bi bi-plus-lg me-1"></i>Add Batch
        </a>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-xl-3 col-md-6">
            <div class="card text-center py-3">
                <div class="fs-2 fw-bold text-success">@good</div>
                <div class="small text-muted">Good (&gt; 60 days)</div>
            </div>
        </div>
        <div class="col-xl-3 col-md-6">
            <div class="card text-center py-3">
                <div class="fs-2 fw-bold text-warning">@warning</div>
                <div class="small text-muted">Expiring (30–60 days)</div>
            </div>
        </div>
        <div class="col-xl-3 col-md-6">
            <div class="card text-center py-3">
                <div class="fs-2 fw-bold text-danger">@critical</div>
                <div class="small text-muted">Critical (&lt; 30 days)</div>
            </div>
        </div>
        <div class="col-xl-3 col-md-6">
            <div class="card text-center py-3">
                <div class="fs-2 fw-bold text-primary">@expired</div>
                <div class="small text-muted">Expired</div>
            </div>
        </div>
    </div>

    <div class="card mb-4">
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-4">
                    <label class="form-label small text-muted">Search</label>
                    <div class="input-group">
                        <span class="input-group-text"><i class="bi bi-search"></i></span>
                        <input type="text" class="form-control" id="searchInput" placeholder="Drug, pharmacy, batch...">
                    </div>
                </div>
                <div class="col-md-3">
                    <label class="form-label small text-muted">Status</label>
                    <select class="form-select" id="filterStatus">
                        <option value="">All Status</option>
                        <option value="Good">Good</option>
                        <option value="Warning">Warning</option>
                        <option value="Critical">Critical</option>
                        <option value="Expired">Expired</option>
                    </select>
                </div>
                <div class="col-md-3 d-flex align-items-end">
                    <button class="btn btn-outline-secondary w-100" onclick="resetFilters()">
                        <i class="bi bi-arrow-counterclockwise me-1"></i>Reset Filters
                    </button>
                </div>
            </div>
        </div>
    </div>

    <div class="card">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-medtrack mb-0" id="batchTable">
                    <thead>
                        <tr>
                            <th>Drug</th>
                            <th>Pharmacy</th>
                            <th>Batch</th>
                            <th>Qty</th>
                            <th>Expiry</th>
                            <th>Status</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in list)
                        {
                            var days = (item.ExpiryDate - now).Days;
                            var statusClass = days < 0 ? "bg-dark" : days <= 30 ? "bg-danger" : days <= 60 ? "bg-warning text-dark" : "bg-success";
                            var statusText = days < 0 ? "Expired" : days <= 30 ? "Critical" : days <= 60 ? "Warning" : "Good";
                            var rowClass = days < 0 ? "table-secondary text-decoration-line-through opacity-75" : days <= 30 ? "table-danger" : days <= 60 ? "table-warning" : "";
                            <tr class="@rowClass" data-status="@statusText">
                                <td class="fw-semibold">@item.Drug.GenericName</td>
                                <td>@item.Pharmacy.Name</td>
                                <td><code class="small">@item.BatchNo</code></td>
                                <td>@item.Quantity</td>
                                <td>@item.ExpiryDate.ToString("yyyy-MM-dd")</td>
                                <td><span class="badge @statusClass">@statusText</span></td>
                                <td class="text-end">
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-warning" title="Edit">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger" title="Delete">
                                        <i class="bi bi-trash"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                        @if (!list.Any())
                        {
                            <tr>
                                <td colspan="7" class="text-center py-5 text-muted">
                                    <i class="bi bi-inbox fs-1 d-block mb-2"></i>
                                    No inventory batches found.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
        <div class="card-footer bg-transparent">
            <span class="text-muted small" id="rowCount">Showing @list.Count items</span>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function filterRows() {
            var search = $('#searchInput').val().toLowerCase();
            var status = $('#filterStatus').val();
            var visible = 0;

            $('#batchTable tbody tr').each(function () {
                var $row = $(this);
                if ($row.find('td[colspan]').length) return;

                var text = $row.text().toLowerCase();
                var rowStatus = $row.data('status');

                var show = true;
                if (search && text.indexOf(search) === -1) show = false;
                if (status && rowStatus !== status) show = false;

                $row.toggle(show);
                if (show) visible++;
            });

            $('#rowCount').text('Showing ' + visible + ' items');
        }

        function resetFilters() {
            $('#searchInput').val('');
            $('#filterStatus').val('');
            $('#batchTable tbody tr').show();
            $('#rowCount').text('Showing @list.Count items');
        }

        $('#searchInput').on('keyup', filterRows);
        $('#filterStatus').on('change', filterRows);
    </script>
}
