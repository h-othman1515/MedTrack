@model IEnumerable<MedTrackJordan.Models.MedicationBatch>
@{ ViewData["Title"] = "Inventory"; }

<div class="d-flex justify-content-between align-items-center mb-4">
    <h3 class="fw-bold"><i class="bi bi-box-seam me-2"></i>Inventory Dashboard</h3>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-lg me-1"></i>Add Batch
    </a>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-3">
        <div class="card border-0 bg-success bg-opacity-10">
            <div class="card-body">
                <div class="d-flex align-items-center">
                    <i class="bi bi-check-circle-fill text-success fs-2 me-3"></i>
                    <div>
                        <div class="small text-muted">Good (> 60 days)</div>
                        <div class="fw-bold fs-5">
                            @Model.Count(b => (b.ExpiryDate - DateTime.UtcNow).Days > 60)
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 bg-warning bg-opacity-10">
            <div class="card-body">
                <div class="d-flex align-items-center">
                    <i class="bi bi-exclamation-circle-fill text-warning fs-2 me-3"></i>
                    <div>
                        <div class="small text-muted">Expiring (30-60 days)</div>
                        <div class="fw-bold fs-5">
                            @Model.Count(b => { var d = (b.ExpiryDate - DateTime.UtcNow).Days; return d > 30 && d <= 60; })
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 bg-danger bg-opacity-10">
            <div class="card-body">
                <div class="d-flex align-items-center">
                    <i class="bi bi-exclamation-triangle-fill text-danger fs-2 me-3"></i>
                    <div>
                        <div class="small text-muted">Critical (< 30 days)</div>
                        <div class="fw-bold fs-5">
                            @Model.Count(b => { var d = (b.ExpiryDate - DateTime.UtcNow).Days; return d >= 0 && d <= 30; })
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 bg-dark bg-opacity-10">
            <div class="card-body">
                <div class="d-flex align-items-center">
                    <i class="bi bi-x-circle-fill text-dark fs-2 me-3"></i>
                    <div>
                        <div class="small text-muted">Expired</div>
                        <div class="fw-bold fs-5">
                            @Model.Count(b => (b.ExpiryDate - DateTime.UtcNow).Days < 0)
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="card shadow-sm border-0">
    <div class="table-responsive">
        <table class="table table-hover mb-0 align-middle">
            <thead class="table-light">
                <tr>
                    <th>Drug</th>
                    <th>Pharmacy</th>
                    <th>Batch</th>
                    <th>Qty</th>
                    <th>Expiry</th>
                    <th>Status</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    var days = (item.ExpiryDate - DateTime.UtcNow).Days;
                    var statusClass = days < 0 ? "bg-dark" : days <= 30 ? "bg-danger" : days <= 60 ? "bg-warning text-dark" : "bg-success";
                    var statusText = days < 0 ? "Expired" : days <= 30 ? $"Critical ({days}d)" : days <= 60 ? $"Warning ({days}d)" : "Good";
                    var rowClass = days < 0 ? "table-secondary text-decoration-line-through opacity-75" : days <= 30 ? "table-danger" : days <= 60 ? "table-warning" : "";

                    <tr class="@rowClass">
                        <td class="fw-semibold">@item.Drug.GenericName</td>
                        <td>@item.Pharmacy.Name</td>
                        <td><code class="small">@item.BatchNo</code></td>
                        <td>@item.Quantity</td>
                        <td>@item.ExpiryDate.ToString("yyyy-MM-dd")</td>
                        <td><span class="badge @statusClass">@statusText</span></td>
                        <td class="text-end">
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-warning">
                                <i class="bi bi-pencil"></i>
                            </a>
                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger">
                                <i class="bi bi-trash"></i>
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    @if (!Model.Any())
    {
        <div class="text-center py-5 text-muted">
            <i class="bi bi-box-seam fs-1"></i>
            <p class="mt-2">No inventory batches found.</p>
        </div>
    }
</div>