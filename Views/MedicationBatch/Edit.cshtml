@model MedTrack.Models.MedicationBatch
@{
    ViewData["Title"] = "Edit Batch";
    ViewData["PageIcon"] = "bi-pencil-square";
    ViewData["Subtitle"] = "Update inventory batch details";
    ViewData["BackUrl"] = Url.Action("Index");
}

<div class="fade-in">
    <partial name="_PageHeader" />

    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card">
                <div class="card-body p-4">
                    <form asp-action="Edit">
                        <input type="hidden" asp-for="Id" />
                        <input type="hidden" asp-for="AddedAt" />
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small"></div>

                        <div class="mb-3">
                            <label asp-for="PharmacyId" class="form-label fw-semibold">Pharmacy</label>
                            <select asp-for="PharmacyId" class="form-select"
                                    asp-items="@(new SelectList(ViewBag.Pharmacies, "Id", "Name"))">
                            </select>
                            <span asp-validation-for="PharmacyId" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="DrugId" class="form-label fw-semibold">Drug</label>
                            <select asp-for="DrugId" class="form-select"
                                    asp-items="@(new SelectList(ViewBag.Drugs, "Id", "GenericName"))">
                            </select>
                            <span asp-validation-for="DrugId" class="text-danger small"></span>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="Quantity" class="form-label fw-semibold"></label>
                                <input asp-for="Quantity" class="form-control" type="number" min="1" />
                                <span asp-validation-for="Quantity" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="BatchNo" class="form-label fw-semibold"></label>
                                <input asp-for="BatchNo" class="form-control" />
                                <span asp-validation-for="BatchNo" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="mb-4">
                            <label asp-for="ExpiryDate" class="form-label fw-semibold"></label>
                            <input asp-for="ExpiryDate" class="form-control" type="date" />
                            <span asp-validation-for="ExpiryDate" class="text-danger small"></span>
                        </div>

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-primary fw-semibold">
                                <i class="bi bi-check-lg me-1"></i>Save
                            </button>
                            <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
